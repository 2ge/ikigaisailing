---
/**
 * /admin/seo/san-blas and /admin/seo/global — the keyword portfolio for each strategy set,
 * SORTED BY IMPORTANCE (priority = volume × winnability) so the owner focuses on the top
 * keywords first. Primary target + est. volume/KD + priority + current rank, each expandable
 * to its 5 spokes. Basic-Auth gated, noindex, out of sitemap. Data: src/data/seoKeywords.ts.
 *
 * "Current rank" needs a live source (GSC service account — not yet wired). SEMrush data shows
 * the site ranks only for incidental blog terms, so every commercial target here is unranked.
 */
import '../../../styles/global.css';
import { SETS, rankedClusters, type SetId } from '../../../data/seoKeywords';
import gsc from '../../../data/gsc-ranks.json';

const rankMap = new Map((gsc.queries as any[]).map((q) => [q.query, q]));

export function getStaticPaths() {
  return (Object.keys(SETS) as SetId[]).map((id) => ({ params: { set: id } }));
}
const setId = Astro.params.set as SetId;
const set = { id: setId, ...SETS[setId] };
const otherId = (setId === 'san-blas' ? 'global' : 'san-blas') as SetId;
const other = { id: otherId, ...SETS[otherId] };
const rows = rankedClusters(setId);

const kdTone = (kd = '') => /extrem/i.test(kd) ? 'text-emerald-400' : /very low|^low$/i.test(kd) ? 'text-emerald-300' : 'text-amber-300';
const tier = (s: number) => s >= 120 ? { c: 'text-emerald-300 border-emerald-500/50 bg-emerald-500/10', t: 'P1' }
  : s >= 55 ? { c: 'text-amber-300 border-amber-500/50 bg-amber-500/10', t: 'P2' }
  : { c: 'text-slate-400 border-white/15 bg-white/5', t: 'P3' };
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex, nofollow, noarchive" />
    <title>Ikigai · SEO · {set.title}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <style is:global>:root{color-scheme:dark} body{background:#060a0b}</style>
  </head>
  <body class="min-h-screen font-sans text-slate-200 antialiased">
    <main class="mx-auto max-w-4xl px-5 py-8">
      <header class="mb-5 border-b border-emerald-500/20 pb-4">
        <div class="flex flex-wrap items-center justify-between gap-3">
          <p class="font-mono text-xs uppercase tracking-[0.3em] text-emerald-400/80">/admin · seo · keywords by priority</p>
          <nav class="flex gap-2 font-mono text-xs">
            <a href="/admin/seo/san-blas/" class={`rounded-full border px-3 py-1.5 ${set.id==='san-blas'?'border-emerald-400 text-emerald-300 bg-emerald-500/10':'border-white/15 text-slate-400 hover:text-emerald-300'}`}>San Blas</a>
            <a href="/admin/seo/global/" class={`rounded-full border px-3 py-1.5 ${set.id==='global'?'border-emerald-400 text-emerald-300 bg-emerald-500/10':'border-white/15 text-slate-400 hover:text-emerald-300'}`}>Global</a>
            <a href="/admin/seo/" class="rounded-full border border-white/15 px-3 py-1.5 text-slate-400 hover:text-emerald-300">matrix</a>
          </nav>
        </div>
        <h1 class="mt-3 font-display text-3xl text-emerald-300">{set.title}</h1>
        <p class="mt-1 text-sm text-slate-400">{set.tagline}</p>
        <p class="mt-1 font-mono text-[0.7rem] text-slate-500">{set.window} · {rows.length} primary keywords, sorted by importance</p>
      </header>

      <p class="mb-5 rounded-lg border border-white/10 bg-white/[0.02] p-3 text-[0.7rem] leading-relaxed text-slate-400">
        <b class="text-slate-300">Priority</b> = monthly volume × winnability (lower difficulty scored higher) → work top-down.
        <b class="text-slate-300">Rank</b> = live Google position from Search Console (refreshed {gsc.generatedAt}, last-28-day avg).
        <span class="text-rose-400">n/r</span> = no impressions in 28 days (effectively unranked for that term). Click a row for its spokes.
      </p>

      <div class="space-y-2">
        {rows.map((r, i) => {
          const tg = tier(r.score);
          const g = rankMap.get(r.primary);
          return (
            <details class="group rounded-xl border border-white/10 bg-white/[0.02]">
              <summary class="grid cursor-pointer grid-cols-[2rem_1fr_auto] items-center gap-3 px-3 py-2.5">
                <span class="text-center font-mono text-xs text-slate-600">{i + 1}</span>
                <span class="min-w-0">
                  <span class="text-sm text-slate-100">{r.primary}</span>
                  <span class="ml-2 rounded bg-white/5 px-1.5 py-0.5 font-mono text-[0.6rem] uppercase text-slate-400">{r.locale}</span>
                </span>
                <span class="flex items-center gap-2 font-mono text-[0.7rem]">
                  <span class="text-slate-300">{r.vol ? `${r.vol}/mo` : '—'}</span>
                  <span class={`whitespace-nowrap ${kdTone(r.kd)}`} title={`difficulty: ${r.kd}`}>{(r.kd||'').replace(/\s*\(0\)/,'')}</span>
                  {g
                    ? <span class={`rounded border px-1.5 py-0.5 ${g.position<=10?'border-emerald-500/40 text-emerald-300':g.position<=20?'border-amber-500/40 text-amber-300':'border-white/15 text-slate-400'}`} title={`GSC: ${g.impressions} impressions, ${g.clicks} clicks (28d)`}>#{g.position}</span>
                    : <span class="rounded border border-rose-500/30 px-1.5 py-0.5 text-rose-400/80" title="no GSC impressions in 28d">n/r</span>}
                  <span class={`w-12 rounded border px-1.5 py-0.5 text-center ${tg.c}`}>{tg.t}·{r.score}</span>
                </span>
              </summary>
              <div class="border-t border-white/5 px-3 py-2.5">
                <p class="mb-1.5 font-mono text-[0.6rem] uppercase tracking-widest text-slate-600">supporting spokes</p>
                <ul class="flex flex-wrap gap-1.5">
                  {(r.spokes ?? []).map((s) => <li class="rounded-md border border-white/10 bg-white/[0.03] px-2 py-1 font-mono text-[0.7rem] text-slate-400">{s}</li>)}
                  {(!r.spokes || r.spokes.length === 0) && <li class="font-mono text-[0.7rem] text-slate-600">— no spokes yet —</li>}
                </ul>
              </div>
            </details>
          );
        })}
      </div>

      <footer class="mt-8 flex items-center justify-between border-t border-white/5 pt-4 font-mono text-[0.65rem] text-slate-600">
        <span>src/data/seoKeywords.ts</span>
        <a href={`/admin/seo/${other.id}/`} class="text-slate-400 hover:text-emerald-300">→ {other.title}</a>
      </footer>
    </main>
  </body>
</html>
