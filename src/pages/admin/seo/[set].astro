---
/**
 * /admin/seo/san-blas and /admin/seo/global — the full keyword portfolio per set,
 * grouped by language (primary targets + their 5 spokes). Basic-Auth gated, noindex,
 * out of sitemap. Data: src/data/seoPortfolio.ts.
 */
import '../../../styles/global.css';
import { PORTFOLIO, setById } from '../../../data/seoPortfolio';

export function getStaticPaths() {
  return PORTFOLIO.map((s) => ({ params: { set: s.id } }));
}
const { set: setId } = Astro.params;
const set = setById(setId!)!;
const other = PORTFOLIO.find((s) => s.id !== set.id)!;
const totalKw = set.locales.reduce((n, b) => n + b.clusters.reduce((m, c) => m + 1 + c.spokes.length, 0), 0);
const kdTone = (kd = '') => /extrem/i.test(kd) ? 'text-emerald-400' : /very low|^low$/i.test(kd) ? 'text-emerald-300' : 'text-amber-300';
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex, nofollow, noarchive" />
    <title>Ikigai · SEO · {set.title}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <style is:global>:root{color-scheme:dark} body{background:#060a0b}</style>
  </head>
  <body class="min-h-screen font-sans text-slate-200 antialiased">
    <main class="mx-auto max-w-4xl px-5 py-8">
      <header class="mb-6 border-b border-emerald-500/20 pb-4">
        <div class="flex flex-wrap items-center justify-between gap-3">
          <p class="font-mono text-xs uppercase tracking-[0.3em] text-emerald-400/80">/admin · seo · keyword portfolio</p>
          <nav class="flex gap-2 font-mono text-xs">
            <a href="/admin/seo/san-blas/" class={`rounded-full border px-3 py-1.5 ${set.id==='san-blas'?'border-emerald-400 text-emerald-300 bg-emerald-500/10':'border-white/15 text-slate-400 hover:text-emerald-300'}`}>San Blas</a>
            <a href="/admin/seo/global/" class={`rounded-full border px-3 py-1.5 ${set.id==='global'?'border-emerald-400 text-emerald-300 bg-emerald-500/10':'border-white/15 text-slate-400 hover:text-emerald-300'}`}>Global</a>
            <a href="/admin/seo/" class="rounded-full border border-white/15 px-3 py-1.5 text-slate-400 hover:text-emerald-300">matrix</a>
          </nav>
        </div>
        <h1 class="mt-3 font-display text-3xl text-emerald-300">{set.title}</h1>
        <p class="mt-1 text-sm text-slate-400">{set.tagline}</p>
        <p class="mt-1 font-mono text-[0.7rem] text-slate-500">{set.window} · {totalKw} keywords across {set.locales.length} languages</p>
      </header>

      <div class="space-y-8">
        {set.locales.map((block) => (
          <section>
            <h2 class="mb-3 flex items-center gap-2 font-mono text-sm uppercase tracking-[0.2em] text-emerald-400/80">
              <span class="inline-block h-px w-6 bg-current opacity-50"></span>{block.label}
            </h2>
            <div class="space-y-3">
              {block.clusters.map((c) => (
                <div class="card rounded-xl border border-white/10 bg-white/[0.02] p-4">
                  <div class="flex flex-wrap items-baseline justify-between gap-2">
                    <p class="font-semibold text-slate-100">{c.primary}</p>
                    <p class="font-mono text-[0.7rem] text-slate-500">
                      {c.vol != null && <span class="text-slate-300">{c.vol}/mo</span>}
                      {c.kd && <span class={`ml-2 ${kdTone(c.kd)}`}>KD {c.kd}</span>}
                    </p>
                  </div>
                  <p class="mt-1 font-mono text-[0.6rem] uppercase tracking-widest text-slate-600">primary</p>
                  <ul class="mt-2 flex flex-wrap gap-1.5">
                    {c.spokes.map((s) => (
                      <li class="rounded-md border border-white/10 bg-white/[0.03] px-2 py-1 font-mono text-[0.7rem] text-slate-400">{s}</li>
                    ))}
                  </ul>
                </div>
              ))}
            </div>
          </section>
        ))}
      </div>

      <footer class="mt-10 flex items-center justify-between border-t border-white/5 pt-4 font-mono text-[0.65rem] text-slate-600">
        <span>src/data/seoPortfolio.ts</span>
        <a href={`/admin/seo/${other.id}/`} class="text-slate-400 hover:text-emerald-300">→ {other.title}</a>
      </footer>
    </main>
  </body>
</html>
