---
/**
 * /admin/seo/plan — the living SEO strategy plan with done/now/todo status per step.
 * Edit src/data/seoPlan.ts to update progress; this page reflects it. Basic-Auth gated, noindex.
 */
import '../../../styles/global.css';
import { PHASES, SPRINT, DECISIONS, STRATEGY, PLAN_UPDATED, type Status } from '../../../data/seoPlan';

const allSteps = PHASES.flatMap((p) => p.steps);
const done = allSteps.filter((s) => s.status === 'done').length;
const now = allSteps.filter((s) => s.status === 'now').length;
const pct = Math.round((done / allSteps.length) * 100);

const dot: Record<Status, string> = {
  done: 'bg-emerald-400 border-emerald-400',
  now: 'bg-amber-400 border-amber-400 animate-pulse',
  todo: 'bg-transparent border-slate-600',
};
const txt: Record<Status, string> = { done: 'text-slate-400 line-through decoration-emerald-500/40', now: 'text-amber-200', todo: 'text-slate-300' };
const badge: Record<Status, string> = {
  done: 'text-emerald-400 border-emerald-500/40', now: 'text-amber-300 border-amber-500/40', todo: 'text-slate-500 border-white/15',
};
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex, nofollow, noarchive" />
    <title>Ikigai · SEO · Plan</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <style is:global>:root{color-scheme:dark} body{background:#060a0b}</style>
  </head>
  <body class="min-h-screen font-sans text-slate-200 antialiased">
    <main class="mx-auto max-w-3xl px-5 py-8">
      <header class="mb-5 border-b border-emerald-500/20 pb-4">
        <div class="flex flex-wrap items-center justify-between gap-3">
          <p class="font-mono text-xs uppercase tracking-[0.3em] text-emerald-400/80">/admin · seo · strategy plan</p>
          <nav class="flex gap-2 font-mono text-xs">
            <a href="/admin/seo/" class="rounded-full border border-white/15 px-3 py-1.5 text-slate-400 hover:text-emerald-300">matrix</a>
            <a href="/admin/seo/san-blas/" class="rounded-full border border-white/15 px-3 py-1.5 text-slate-400 hover:text-emerald-300">San Blas</a>
            <a href="/admin/seo/global/" class="rounded-full border border-white/15 px-3 py-1.5 text-slate-400 hover:text-emerald-300">Global</a>
          </nav>
        </div>
        <h1 class="mt-3 font-display text-3xl text-emerald-300">SEO strategy — living plan</h1>
        <p class="mt-2 text-sm leading-relaxed text-slate-400">{STRATEGY}</p>
        <div class="mt-4 flex items-center gap-3">
          <div class="h-2 flex-1 overflow-hidden rounded-full bg-white/10">
            <div class="h-full rounded-full bg-emerald-400" style={`width:${pct}%`}></div>
          </div>
          <span class="font-mono text-xs text-slate-400">{done}/{allSteps.length} done · {now} in progress</span>
        </div>
        <p class="mt-1 font-mono text-[0.65rem] text-slate-600">updated {PLAN_UPDATED} · edit src/data/seoPlan.ts</p>
      </header>

      <!-- the sprint -->
      <section class="mb-6 rounded-xl border border-amber-500/30 bg-amber-500/[0.04] p-4">
        <h2 class="mb-2 font-mono text-[0.7rem] uppercase tracking-[0.2em] text-amber-300/90">▶ Do next (the sprint)</h2>
        <ol class="list-decimal space-y-1 pl-5 text-sm text-slate-300">
          {SPRINT.map((s) => <li>{s}</li>)}
        </ol>
      </section>

      <!-- phases -->
      <div class="space-y-5">
        {PHASES.map((p) => {
          const d = p.steps.filter((s) => s.status === 'done').length;
          return (
            <section class="rounded-xl border border-white/10 bg-white/[0.02] p-4">
              <div class="mb-1 flex items-baseline justify-between gap-2">
                <h2 class="font-mono text-sm text-emerald-300">{p.title}</h2>
                <span class="font-mono text-[0.65rem] text-slate-500">{d}/{p.steps.length}</span>
              </div>
              <p class="mb-3 text-xs text-slate-500">{p.goal}</p>
              <ul class="space-y-2.5">
                {p.steps.map((s) => (
                  <li class="flex items-start gap-3">
                    <span class={`mt-1 h-3 w-3 shrink-0 rounded-full border ${dot[s.status]}`}></span>
                    <div class="min-w-0">
                      <span class={`text-sm ${txt[s.status]}`}>{s.title}</span>
                      <span class={`ml-2 rounded border px-1.5 py-0.5 align-middle font-mono text-[0.6rem] uppercase ${badge[s.status]}`}>{s.status}</span>
                      {s.note && <span class="block font-mono text-[0.65rem] text-slate-600">{s.note}</span>}
                    </div>
                  </li>
                ))}
              </ul>
            </section>
          );
        })}
      </div>

      <!-- open decisions -->
      <section class="mt-6 rounded-xl border border-white/10 bg-white/[0.02] p-4">
        <h2 class="mb-3 font-mono text-[0.7rem] uppercase tracking-[0.2em] text-emerald-400/70">Open decisions — to discuss</h2>
        <ul class="space-y-2">
          {DECISIONS.map((d) => (
            <li class="flex items-start gap-3 text-sm">
              <span class={`mt-1 h-3 w-3 shrink-0 rounded-full border ${dot[d.status]}`}></span>
              <div><span class="text-slate-300">{d.q}</span>{d.answer && <span class="block text-emerald-300">→ {d.answer}</span>}</div>
            </li>
          ))}
        </ul>
      </section>

      <footer class="mt-8 border-t border-white/5 pt-4 font-mono text-[0.65rem] text-slate-600">
        src/data/seoPlan.ts — Claude updates statuses here as work ships, so this page always shows where we are.
      </footer>
    </main>
  </body>
</html>
