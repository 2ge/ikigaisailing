---
/**
 * Single-segment dispatcher: top-level pages, the bespoke designed pages, and
 * the section indexes (trips / activities / blog). The URL segment is localized
 * (e.g. /sk/pribeh/), resolved back to a canonical page key in lib/routes.
 */
import type { Locale } from '../../i18n/ui';
import { topLevelStaticPaths, DEDICATED } from '../../lib/routes';
import AboutView from '../../views/AboutView.astro';
import IkigaiView from '../../views/IkigaiView.astro';
import RouteView from '../../views/RouteView.astro';
import StoryView from '../../views/StoryView.astro';
import SeasonView from '../../views/SeasonView.astro';
import ReviewsView from '../../views/ReviewsView.astro';
import ContactView from '../../views/ContactView.astro';
import TripsIndexView from '../../views/TripsIndexView.astro';
import ActivitiesIndexView from '../../views/ActivitiesIndexView.astro';
import BlogIndexView from '../../views/BlogIndexView.astro';
import FaqView from '../../views/FaqView.astro';
import PageView from '../../views/PageView.astro';

export async function getStaticPaths() {
  return topLevelStaticPaths();
}

const { locale, pageKey } = Astro.props as { locale: Locale; pageKey: string };

const DEDICATED_VIEWS: Record<string, any> = {
  about: AboutView,
  ikigai: IkigaiView,
  route: RouteView,
  story: StoryView,
  'season-2025-26': SeasonView,
  reviews: ReviewsView,
  contact: ContactView,
};
const Dedicated = DEDICATED.has(pageKey) ? DEDICATED_VIEWS[pageKey] : null;
---
{
  Dedicated ? (
    <Dedicated locale={locale} />
  ) : pageKey === 'trips' ? (
    <TripsIndexView locale={locale} />
  ) : pageKey === 'activities' ? (
    <ActivitiesIndexView locale={locale} />
  ) : pageKey === 'blog' ? (
    <BlogIndexView locale={locale} />
  ) : pageKey === 'faq' ? (
    <FaqView locale={locale} />
  ) : (
    <PageView slug={pageKey} locale={locale} />
  )
}
