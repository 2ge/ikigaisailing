---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import PageLayout from '../../../layouts/PageLayout.astro';
import Prose from '../../../components/Prose.astro';
import FaqAccordion from '../../../components/FaqAccordion.astro';
import Gallery from '../../../components/Gallery.astro';
import JsonLd from '../../../components/jsonld/JsonLd.astro';
import { useTranslations, localizePath, defaultLocale, type Locale } from '../../../i18n/ui';
import { WHATSAPP_URL } from '../../../i18n/nav';
import { slugOf, entryForLocale } from '../../../lib/content';
import { breadcrumbs, faqPage, tripProduct } from '../../../lib/schema';

export async function getStaticPaths() {
  const all = await getCollection('trips');
  const slugs = [...new Set(all.map(slugOf))];
  const locales: Locale[] = ['en', 'it', 'es', 'fr', 'sk'];
  return slugs.flatMap((slug) =>
    locales.map((locale) => ({
      params: { locale: locale === defaultLocale ? undefined : locale, slug },
      props: { slug, locale },
    })),
  );
}

const { slug, locale } = Astro.props as { slug: string; locale: Locale };
const t = useTranslations(locale);
const entry = await entryForLocale('trips', slug, locale);
if (!entry) return Astro.redirect('/404/');
const d = entry.data;

const site = Astro.site!.origin;
const url = new URL(Astro.url.pathname, site).href;
const contactHref = localizePath(`/contact/?trip=${encodeURIComponent(d.title)}`, locale);

const schemas = [
  breadcrumbs(site, locale, [
    { name: 'Ikigai Sailing', path: '/' },
    { name: t('nav.trips'), path: '/trips/' },
    { name: d.title, path: `/trips/${slug}/` },
  ]),
  tripProduct(site, url, d),
  ...(d.faq.length ? [faqPage(d.faq)] : []),
];
---

<PageLayout title={d.title} description={d.description} path={`/trips/${slug}/`} ogType="article">
  <Fragment slot="head">
    {schemas.map((s) => <JsonLd schema={s} />)}
  </Fragment>

  {/* hero */}
  <header class="relative isolate overflow-hidden bg-ocean-950">
    {d.heroImage && (
      <Image src={d.heroImage} alt={d.title} width={1800} height={1000} widths={[640, 1024, 1800]} sizes="100vw" loading="eager" class="absolute inset-0 -z-10 h-full w-full object-cover opacity-60" />
    )}
    <div class="absolute inset-0 -z-10 bg-gradient-to-t from-ocean-950 via-ocean-950/50 to-transparent"></div>
    <div class="mx-auto flex min-h-[60vh] max-w-5xl flex-col justify-end px-4 py-16 sm:px-6">
      <p class="coords text-ocean-300">{d.location}{d.membersOnly && ' · ' + t('trip.membersOnly')}</p>
      <h1 class="mt-3 max-w-3xl font-display text-4xl leading-tight text-sand-50 sm:text-6xl">{d.title}</h1>
      <p class="mt-4 max-w-xl text-lg text-sand-100/90">{d.description}</p>
    </div>
  </header>

  <div class="mx-auto grid max-w-5xl gap-12 px-4 py-14 sm:px-6 lg:grid-cols-[1fr_20rem]">
    <article>
      <Prose entry={entry} />
      {d.faq.length > 0 && (
        <section class="mt-12">
          <h2 class="font-display text-2xl text-ocean-950">{t('trip.faq')}</h2>
          <FaqAccordion faq={d.faq} />
        </section>
      )}
      {d.gallery.length > 0 && (
        <section class="mt-12">
          <h2 class="font-display text-2xl text-ocean-950">{t('trip.gallery')}</h2>
          <Gallery images={d.gallery} alt={d.title} />
        </section>
      )}
    </article>

    {/* sticky facts + CTA */}
    <aside class="lg:sticky lg:top-20 lg:self-start">
      <div class="rounded-2xl bg-sand-100 p-6 ring-1 ring-ocean-950/5">
        <dl class="space-y-3 text-sm">
          <div class="flex justify-between"><dt class="text-ink-soft">{t('trip.duration')}</dt><dd class="font-medium text-ocean-950">{d.duration}</dd></div>
          {d.season && <div class="flex justify-between"><dt class="text-ink-soft">{t('trip.season')}</dt><dd class="font-medium text-ocean-950">{d.season}</dd></div>}
          <div class="flex justify-between"><dt class="text-ink-soft">{t('trip.location')}</dt><dd class="font-medium text-ocean-950">{d.location}</dd></div>
          {d.price != null && (
            <div class="flex items-baseline justify-between border-t border-ocean-950/10 pt-3">
              <dt class="text-ink-soft">{t('trip.price')}</dt>
              <dd class="font-display text-2xl text-ocean-700">€{d.price.toLocaleString()}</dd>
            </div>
          )}
        </dl>
        <a href={contactHref} class="mt-5 block rounded-full bg-ocean-700 px-5 py-3 text-center font-semibold text-sand-50 transition hover:bg-ocean-600">
          {t('cta.book')}
        </a>
        <a href={WHATSAPP_URL} target="_blank" rel="noopener" class="mt-2 block rounded-full border border-ocean-300 px-5 py-3 text-center font-semibold text-ocean-700 transition hover:bg-ocean-100">
          {t('cta.whatsapp')}
        </a>
        <p class="mt-4 text-xs leading-relaxed text-ink-soft">{t('footer.nonprofit')}</p>
      </div>
    </aside>
  </div>
</PageLayout>
