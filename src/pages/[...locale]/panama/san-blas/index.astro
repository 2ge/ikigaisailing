---
/**
 * /panama/san-blas/ — the canonical San Blas hub + booking page (+ locale prefix).
 * Renders the season/booking content (pages/<locale>/season-2025-26.md) via SeasonView,
 * which also links down to the geo activity pages. The old /season-2025-26/ URLs 301 here.
 */
import { getCollection } from 'astro:content';
import { LOCALES, type Loc } from '../../../../i18n/segments';
import { slugOf, localeOf } from '../../../../lib/content';
import SeasonView from '../../../../views/SeasonView.astro';

export async function getStaticPaths() {
  const have = new Set(
    (await getCollection('pages')).filter((e) => slugOf(e) === 'season-2025-26').map((e) => localeOf(e) as Loc),
  );
  const locs = have.has('en') ? [...LOCALES] : [...have];
  return locs.map((locale) => ({ params: { locale: locale === 'en' ? undefined : locale }, props: { locale } }));
}
const { locale } = Astro.props;
---
<SeasonView locale={locale} />
