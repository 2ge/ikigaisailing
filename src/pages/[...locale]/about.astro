---
/** Dedicated, designed About page: intro + stats + certifications + crew + vision. */
import { Image } from 'astro:assets';
import PageLayout from '../../layouts/PageLayout.astro';
import SectionHeading from '../../components/SectionHeading.astro';
import WhatsAppButton from '../../components/WhatsAppButton.astro';
import JsonLd from '../../components/jsonld/JsonLd.astro';
import { useTranslations, localizePath, defaultLocale, type Locale } from '../../i18n/ui';
import { entryForLocale } from '../../lib/content';
import { breadcrumbs } from '../../lib/schema';
// crew
import lucaPhoto from '../../assets/crew/luca.webp';
import branoPhoto from '../../assets/crew/brano.jpg';
import paolaPhoto from '../../assets/crew/paola.png';
// certifications
import coni from '../../assets/certs/coni.png';
import aida from '../../assets/certs/aida.png';
import iantd from '../../assets/certs/iantd.png';
import iko from '../../assets/certs/iko.png';
import apnea from '../../assets/certs/apneatotal.png';

export async function getStaticPaths() {
  return (['en', 'it', 'es', 'fr', 'sk'] as Locale[]).map((locale) => ({
    params: { locale: locale === defaultLocale ? undefined : locale },
    props: { locale },
  }));
}
const { locale } = Astro.props as { locale: Locale };
const t = useTranslations(locale);
const lp = (p: string) => localizePath(p, locale);
const page = await entryForLocale('pages', 'about', locale);

const stats = [
  { n: '2022', l: t('home.statsSince') },
  { n: '20+', l: t('home.statsCountries') },
  { n: '10,000+', l: t('home.statsMiles') },
];

const certs = [
  { name: 'CONI', logo: coni, url: 'https://www.coni.it' },
  { name: 'AIDA', logo: aida, url: 'https://www.aidainternational.org' },
  { name: 'IANTD', logo: iantd, url: 'https://www.iantd.com' },
  { name: 'IKO', logo: iko, url: 'https://www.ikointl.com' },
  { name: 'Apnea Total', logo: apnea, url: 'https://www.apneatotal.com' },
];

const crew = [
  {
    name: 'Luca', role: t('about.luca.role'), photo: lucaPhoto, bio: t('about.luca.bio'),
  },
  {
    name: 'Brano', role: t('about.brano.role'), photo: branoPhoto, bio: t('about.brano.bio'),
  },
  {
    name: 'Paola', role: t('about.paola.role'), photo: paolaPhoto, bio: t('about.paola.bio'),
  },
];

const site = Astro.site!.origin;
const crumb = breadcrumbs(site, locale, [
  { name: 'Ikigai Sailing', path: '/' },
  { name: page?.data.title ?? 'About', path: '/about/' },
]);
---

<PageLayout title={page?.data.title ?? 'About Ikigai Sailing'} description={page?.data.description ?? 'Who we are.'} path="/about/">
  <JsonLd slot="head" schema={crumb} />

  {/* hero */}
  <header class="relative isolate overflow-hidden bg-ocean-950">
    {page?.data.heroImage && (
      <Image src={page.data.heroImage} alt={page.data.title} width={1800} height={900} widths={[640, 1024, 1800]} sizes="100vw" priority class="absolute inset-0 -z-10 h-full w-full object-cover opacity-55" />
    )}
    <div class="absolute inset-0 -z-10 bg-gradient-to-t from-ocean-950 via-ocean-950/40 to-transparent"></div>
    <div class="mx-auto flex min-h-[52vh] max-w-4xl flex-col justify-end px-4 py-16 sm:px-6">
      <p class="coords text-ocean-300">{t('about.whoWeAre')}</p>
      <h1 class="mt-3 font-display text-4xl leading-tight text-sand-50 sm:text-5xl">{page?.data.title ?? t('about.title')}</h1>
    </div>
  </header>

  {/* intro */}
  <section class="bg-sand-50 py-16">
    <div class="mx-auto max-w-3xl px-4 text-center sm:px-6">
      <p class="font-display text-2xl leading-snug text-ocean-950 sm:text-3xl">{t('about.intro1')}</p>
      <p class="mt-6 text-lg text-ink-soft">{t('about.intro2')}</p>
    </div>
  </section>

  {/* stats */}
  <section class="bg-ocean-950 py-14 text-sand-50">
    <div class="mx-auto max-w-5xl px-4 sm:px-6">
      <dl class="grid grid-cols-3 gap-2 text-center sm:gap-6">
        {stats.map((s) => (
          <div>
            <dt class="font-display text-2xl text-ocean-300 sm:text-5xl">{s.n}</dt>
            <dd class="coords mt-2 text-sand-100/70">{s.l}</dd>
          </div>
        ))}
      </dl>
    </div>
  </section>

  {/* certifications */}
  <section class="bg-sand-100 py-16">
    <div class="mx-auto max-w-5xl px-4 text-center sm:px-6">
      <SectionHeading eyebrow={t('about.credentials')} title={t('about.certsTitle')} align="center" />
      <ul class="mt-10 flex flex-wrap items-center justify-center gap-x-10 gap-y-8">
        {certs.map((c) => (
          <li>
            <a href={c.url} target="_blank" rel="noopener" title={c.name} class="block opacity-70 grayscale transition hover:opacity-100 hover:grayscale-0">
              <Image src={c.logo} alt={c.name} height={56} class="h-12 w-auto sm:h-14" />
            </a>
          </li>
        ))}
      </ul>
    </div>
  </section>

  {/* crew */}
  <section class="bg-sand-50 py-20">
    <div class="mx-auto max-w-6xl px-4 sm:px-6">
      <SectionHeading eyebrow={t('about.crewEyebrow')} title={t('about.crewTitle')} align="center" />
      <div class="mt-12 grid gap-8 sm:grid-cols-2 lg:grid-cols-3">
        {crew.map((m) => (
          <article class="overflow-hidden rounded-2xl bg-sand-100 ring-1 ring-ocean-950/5">
            <Image src={m.photo} alt={m.name} width={640} height={520} class="aspect-[5/4] w-full object-cover" />
            <div class="p-6">
              <h3 class="font-display text-2xl text-ocean-950">{m.name}</h3>
              <p class="coords mt-1 text-ocean-600">{m.role}</p>
              <p class="mt-3 text-sm leading-relaxed text-ink-soft">{m.bio}</p>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  {/* vision */}
  <section class="bg-ocean-900 py-20 text-sand-50">
    <div class="mx-auto max-w-3xl px-4 text-center sm:px-6">
      <SectionHeading eyebrow={t('about.visionEyebrow')} title={t('about.visionTitle')} align="center" light />
      <p class="mt-6 text-lg leading-relaxed text-sand-100/85">{t('about.visionBody')}</p>
      <div class="mt-8 flex flex-wrap justify-center gap-3">
        <a href={lp('/story/')} class="rounded-full bg-sand-50 px-6 py-3 font-semibold text-ocean-900 transition hover:bg-sand-100">{t('about.readStory')}</a>
        <a href={lp('/ikigai/')} class="rounded-full border border-sand-100/30 px-6 py-3 font-semibold text-sand-50 transition hover:bg-ocean-950/40">{t('about.discoverIkigai')}</a>
      </div>
    </div>
  </section>

  {/* CTA */}
  <section class="bg-coral-500 py-16 text-center text-sand-50">
    <div class="mx-auto max-w-2xl px-4">
      <h2 class="font-display text-2xl sm:text-3xl">{t('contact.title')}</h2>
      <p class="mx-auto mt-3 max-w-md text-sand-50/90">{t('contact.whatsappLead')}</p>
      <WhatsAppButton class="mt-7" />
    </div>
  </section>
</PageLayout>
