---
import PageLayout from '../../../layouts/PageLayout.astro';
import { useTranslations, localizePath, defaultLocale, type Locale } from '../../../i18n/ui';

export async function getStaticPaths() {
  return (['en', 'it', 'es', 'fr', 'sk'] as Locale[]).map((locale) => ({
    params: { locale: locale === defaultLocale ? undefined : locale },
    props: { locale },
  }));
}
const { locale } = Astro.props as { locale: Locale };
const t = useTranslations(locale);
---
<PageLayout title="Thank you — Ikigai Sailing" description="Your booking request is confirmed." path="/booking/thanks/" noindex>
  <section class="grid min-h-[70vh] place-items-center bg-ocean-950 text-center text-sand-50">
    <div class="px-4">
      <p class="coords text-ocean-300">Welcome aboard</p>
      <h1 class="mt-4 font-display text-4xl sm:text-6xl">Fair winds — see you on the water.</h1>
      <p class="mx-auto mt-4 max-w-md text-sand-100/80">
        Your booking is received. We'll email you the next steps shortly. For anything urgent,
        message us on WhatsApp.
      </p>
      <a href={localizePath('/', locale)} class="mt-8 inline-block rounded-full bg-coral-500 px-6 py-3 font-semibold text-sand-50 transition hover:bg-coral-400">
        {t('notfound.cta')}
      </a>
    </div>
  </section>
</PageLayout>
