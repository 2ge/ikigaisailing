---
import { Image } from 'astro:assets';
import PageLayout from '../layouts/PageLayout.astro';
import PageHero from '../components/PageHero.astro';
import { useTranslations, localizePath, defaultLocale, type Locale } from '../i18n/ui';
import { entriesForLocale, slugOf } from '../lib/content';

const { locale } = Astro.props as { locale: Locale };
const t = useTranslations(locale);
const posts = (await entriesForLocale('blog', locale))
  .filter((p) => !p.data.draft)
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());
const fmt = (d: Date) => d.toLocaleDateString(locale, { year: 'numeric', month: 'long', day: 'numeric' });
---
<PageLayout title={`${t('nav.blog')} — Ikigai Sailing`} description="Stories, guides and logbook notes from the crew of Ikigai — San Blas sailing, freediving, slow travel and life aboard a Catana 47." path="/blog/">
  <PageHero eyebrow="Logbook" title={t('nav.blog')} lead="Guides and stories from aboard — San Blas, freediving, slow ocean travel and life on a Catana 47." />
  <div class="mx-auto max-w-6xl px-4 py-14 sm:px-6">
    <div class="grid gap-8 sm:grid-cols-2 lg:grid-cols-3">
      {posts.map((post) => (
        <a href={localizePath(`/blog/${slugOf(post)}/`, locale)} class="group flex flex-col">
          <div class="aspect-[16/10] overflow-hidden rounded-xl bg-ocean-100">
            {post.data.image && <Image src={post.data.image} alt={post.data.title} width={560} height={350} loading="lazy" class="h-full w-full object-cover transition duration-500 group-hover:scale-105" />}
          </div>
          <p class="coords mt-4 text-ocean-600">{fmt(post.data.pubDate)}</p>
          <h2 class="mt-1.5 font-display text-xl leading-snug text-ocean-950 group-hover:text-ocean-700">{post.data.title}</h2>
          <p class="mt-2 line-clamp-2 text-sm text-ink-soft">{post.data.description}</p>
        </a>
      ))}
    </div>
  </div>
</PageLayout>
