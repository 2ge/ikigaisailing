---
/** Dedicated route page: hero + clean narrative + live map + destinations + CTA. */
import { Image } from 'astro:assets';
import PageLayout from '../layouts/PageLayout.astro';
import SectionHeading from '../components/SectionHeading.astro';
import VoyageTimeline from '../components/VoyageTimeline.astro';
import MapEmbed from '../components/MapEmbed.astro';
import DestinationFlags from '../components/DestinationFlags.astro';
import WhatsAppButton from '../components/WhatsAppButton.astro';
import JsonLd from '../components/jsonld/JsonLd.astro';
import { useTranslations, localizePath, defaultLocale, type Locale } from '../i18n/ui';
import { WHATSAPP_URL } from '../i18n/nav';
import { entryForLocale } from '../lib/content';
import { breadcrumbs } from '../lib/schema';

const { locale } = Astro.props as { locale: Locale };
const t = useTranslations(locale);
const lp = (p: string) => localizePath(p, locale);
const page = await entryForLocale('pages', 'route', locale);

const site = Astro.site!.origin;
const crumb = breadcrumbs(site, locale, [
  { name: 'Ikigai Sailing', path: '/' },
  { name: page?.data.title ?? 'The Route', path: '/route/' },
]);
---

<PageLayout title={page?.data.title ?? 'The Route — Ikigai Sailing'} description={page?.data.description ?? 'Where Ikigai is sailing now and next.'} path="/route/">
  <JsonLd slot="head" schema={crumb} />

  {/* hero */}
  <header class="relative isolate overflow-hidden bg-ocean-950">
    {page?.data.heroImage && (
      <Image src={page.data.heroImage} alt={page.data.title} width={1800} height={900} widths={[640, 1024, 1800]} sizes="100vw" priority class="absolute inset-0 -z-10 h-full w-full object-cover opacity-55" />
    )}
    <div class="absolute inset-0 -z-10 bg-gradient-to-t from-ocean-950 via-ocean-950/40 to-transparent"></div>
    <div class="mx-auto flex min-h-[52vh] max-w-4xl flex-col justify-end px-4 py-16 sm:px-6">
      <p class="coords text-ocean-300">9°33′N · 78°57′W — Guna Yala, Panama</p>
      <h1 class="mt-3 font-display text-4xl leading-tight text-sand-50 sm:text-5xl">{page?.data.title ?? 'The Route'}</h1>
      <p class="mt-4 max-w-2xl text-lg text-sand-100/90">{page?.data.lead ?? page?.data.description}</p>
    </div>
  </header>

  {/* live map */}
  <section class="bg-ocean-900 py-16 text-sand-50">
    <div class="mx-auto max-w-5xl px-4 sm:px-6">
      <SectionHeading eyebrow={t('home.routeEyebrow')} title={t('home.routeTitle')} light />
      <p class="mt-4 max-w-xl text-sand-100/85">{t('home.routeBody')}</p>
      <div class="mt-8"><MapEmbed label={t('home.routeMapBtn')} /></div>
    </div>
  </section>

  {/* voyage logbook */}
  {page?.data.voyage?.length > 0 && (
    <section class="bg-sand-50 py-16 sm:py-20">
      <div class="mx-auto max-w-5xl px-4 sm:px-6">
        <SectionHeading eyebrow={t('home.logbook')} title={t('route.voyageTitle')} align="center" />
        <div class="mt-12">
          <VoyageTimeline years={page.data.voyage} nowLabel={t('route.youAreHere')} />
        </div>
      </div>
    </section>
  )}

  {/* the road ahead */}
  {page?.data.ahead && (
    <section class="bg-ocean-900 py-16 text-sand-50 sm:py-20">
      <div class="mx-auto max-w-3xl px-4 text-center sm:px-6">
        <p class="coords text-ocean-300">2027 →</p>
        <h2 class="mt-3 font-display text-2xl text-sand-50 sm:text-3xl">{page.data.aheadTitle ?? t('route.voyageTitle')}</h2>
        <p class="mx-auto mt-5 max-w-2xl text-lg leading-relaxed text-sand-100/90">{page.data.ahead}</p>
      </div>
    </section>
  )}

  {/* destinations reached */}
  <section class="bg-ocean-950 py-16 text-sand-50">
    <div class="mx-auto max-w-6xl px-4 sm:px-6">
      <p class="coords mb-8 text-center text-ocean-300">{t('home.destinations')}</p>
      <DestinationFlags />
    </div>
  </section>

  {/* CTA */}
  <section class="bg-coral-500 py-16 text-center text-sand-50">
    <div class="mx-auto max-w-2xl px-4">
      <h2 class="font-display text-2xl sm:text-3xl">{t('contact.title')}</h2>
      <p class="mx-auto mt-3 max-w-md text-sand-50/90">{t('contact.whatsappLead')}</p>
      <div class="mt-7 flex flex-wrap justify-center gap-3">
        <a href={lp('/trips/')} class="rounded-full bg-sand-50 px-6 py-3 font-semibold text-coral-600 transition hover:bg-sand-100">{t('cta.discoverTrips')}</a>
        <WhatsAppButton />
      </div>
    </div>
  </section>
</PageLayout>
