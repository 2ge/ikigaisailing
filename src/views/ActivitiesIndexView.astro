---
import PageLayout from '../layouts/PageLayout.astro';
import PageHero from '../components/PageHero.astro';
import ActivityCard from '../components/ActivityCard.astro';
import Prose from '../components/Prose.astro';
import { useTranslations, defaultLocale, type Locale } from '../i18n/ui';
import { entriesForLocale, entryForLocale } from '../lib/content';

const { locale } = Astro.props as { locale: Locale };
const t = useTranslations(locale);
const activities = (await entriesForLocale('activities', locale)).sort((a, b) => a.data.order - b.data.order);
const intro = await entryForLocale('pages', 'activities', locale);
---
<PageLayout title={`${t('nav.activities')} — Ikigai Sailing`} description={intro?.data.description ?? 'Activities aboard Ikigai: yoga, freediving, meditation, Janzu and more.'} path="/activities/">
  <PageHero eyebrow="On board" title={intro?.data.title ?? t('nav.activities')} lead={intro?.data.description} />
  <div class="mx-auto max-w-6xl px-4 py-14 sm:px-6">
    {intro && <article class="mb-12 max-w-3xl"><Prose entry={intro} /></article>}
    <div class="grid grid-cols-2 gap-4 sm:grid-cols-3 lg:grid-cols-4">
      {activities.map((activity) => <ActivityCard activity={activity} locale={locale} />)}
    </div>
  </div>
</PageLayout>
