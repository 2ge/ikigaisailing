---
import PageLayout from '../layouts/PageLayout.astro';
import PageHero from '../components/PageHero.astro';
import { useTranslations, defaultLocale, type Locale } from '../i18n/ui';
import { WHATSAPP_URL, SOCIALS } from '../i18n/nav';
import { entryForLocale } from '../lib/content';

const { locale } = Astro.props as { locale: Locale };
const t = useTranslations(locale);
const intro = await entryForLocale('pages', 'contact', locale);
---
<PageLayout title={`${t('nav.contact')} — Ikigai Sailing`} description={intro?.data.description ?? t('contact.whatsappLead')} path="/contact/">
  <PageHero eyebrow="9°33′N · 78°57′W" title={t('contact.title')} lead={t('contact.whatsappLead')} />
  <div class="mx-auto grid max-w-5xl gap-12 px-4 py-14 sm:px-6 lg:grid-cols-2">
    <div>
      <a href={WHATSAPP_URL} target="_blank" rel="noopener" class="flex items-center gap-3 rounded-2xl bg-[#25D366] px-6 py-4 font-semibold text-white shadow-md transition hover:brightness-105">
        <svg class="h-6 w-6" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path d="M12.05 2a9.94 9.94 0 0 0-8.6 14.92L2 22l5.23-1.37A9.94 9.94 0 1 0 12.05 2Zm0 18.18c-1.5 0-2.97-.4-4.25-1.16l-.3-.18-3.1.81.83-3.03-.2-.31a8.26 8.26 0 1 1 7.02 3.87Z"/></svg>
        {t('cta.whatsapp')} — +39 331 32 926 29
      </a>
      <p class="mt-4 text-sm text-ink-soft">{t('footer.nonprofit')}</p>
      <div class="mt-8 flex gap-4">
        <a href={SOCIALS.instagram} target="_blank" rel="noopener" class="coords text-ocean-600 hover:text-ocean-800">Instagram ↗</a>
        <a href={SOCIALS.facebook} target="_blank" rel="noopener" class="coords text-ocean-600 hover:text-ocean-800">Facebook ↗</a>
        <a href={SOCIALS.youtube} target="_blank" rel="noopener" class="coords text-ocean-600 hover:text-ocean-800">YouTube ↗</a>
      </div>
    </div>

    {/* Pages Function posts to /api/contact — progressive: works as mailto fallback if JS off */}
    <form id="contact-form" method="POST" action="/api/contact" class="space-y-4 rounded-2xl bg-sand-100 p-6 ring-1 ring-ocean-950/5">
      <input type="text" name="trip" id="cf-trip" hidden />
      <div style="position:absolute;left:-9999px" aria-hidden="true"><label>Leave blank<input name="company" tabindex="-1" autocomplete="off" /></label></div>
      <div>
        <label for="cf-name" class="coords text-ocean-700">{t('contact.name')}</label>
        <input required type="text" name="name" id="cf-name" class="mt-1 w-full rounded-lg border border-ocean-950/10 bg-sand-50 px-3 py-2.5 focus:border-ocean-400 focus:outline-none" />
      </div>
      <div>
        <label for="cf-email" class="coords text-ocean-700">{t('contact.email')}</label>
        <input required type="email" name="email" id="cf-email" class="mt-1 w-full rounded-lg border border-ocean-950/10 bg-sand-50 px-3 py-2.5 focus:border-ocean-400 focus:outline-none" />
      </div>
      <div>
        <label for="cf-msg" class="coords text-ocean-700">{t('contact.message')}</label>
        <textarea required name="message" id="cf-msg" rows="5" class="mt-1 w-full rounded-lg border border-ocean-950/10 bg-sand-50 px-3 py-2.5 focus:border-ocean-400 focus:outline-none"></textarea>
      </div>
      <div class="cf-turnstile" data-sitekey="1x00000000000000000000AA"></div>
      <button type="submit" class="w-full rounded-full bg-ocean-700 px-5 py-3 font-semibold text-sand-50 transition hover:bg-ocean-600">{t('contact.send')}</button>
      <p id="cf-status" class="hidden text-center text-sm text-ocean-700">{t('contact.sent')}</p>
    </form>
  </div>

  <script src="https://challenges.cloudflare.com/turnstile/v0/api.js" async defer></script>
  <script is:inline>
    // prefill trip name from ?trip=
    const params = new URLSearchParams(location.search);
    const trip = params.get('trip');
    if (trip) {
      document.getElementById('cf-trip').value = trip;
      const msg = document.getElementById('cf-msg');
      if (msg && !msg.value) msg.value = `I'm interested in: ${trip}\n\n`;
    }
    document.getElementById('contact-form')?.addEventListener('submit', async (e) => {
      e.preventDefault();
      const form = e.target;
      const res = await fetch(form.action, { method: 'POST', body: new FormData(form) });
      if (res.ok) { form.reset(); document.getElementById('cf-status').classList.remove('hidden'); }
    });
  </script>
</PageLayout>
