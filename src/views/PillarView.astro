---
/**
 * /panama/san-blas/ pillar (hub). Targets the geo head term, links down to every San Blas
 * activity page + the booking. Content from landings/<locale>/pillar.md.
 */
import { Image } from 'astro:assets';
import PageLayout from '../layouts/PageLayout.astro';
import Prose from '../components/Prose.astro';
import FaqAccordion from '../components/FaqAccordion.astro';
import JsonLd from '../components/jsonld/JsonLd.astro';
import { useTranslations, localizePath, type Locale } from '../i18n/ui';
import { WHATSAPP_URL } from '../i18n/nav';
import { entryForLocale, availableLocalesFor } from '../lib/content';
import { breadcrumbs, faqPage } from '../lib/schema';

const { locale } = Astro.props as { locale: Locale };
const t = useTranslations(locale);
const entry = await entryForLocale('landings', 'pillar', locale);
if (!entry) return Astro.redirect('/404/');
const availableLocales = await availableLocalesFor('landings', 'pillar');
const d = entry.data;
const path = '/panama/san-blas/';
const site = Astro.site!.origin;

// activity cards
const ACTS = ['freediving', 'yoga', 'janzu', 'meditation'];
const cards = (await Promise.all(ACTS.map((a) => entryForLocale('landings', a, locale))))
  .filter(Boolean)
  .map((e: any, i) => ({ slug: ACTS[i], title: e.data.title, hero: e.data.heroImage }));

const schemas = [
  breadcrumbs(site, locale, [{ name: 'Ikigai Sailing', path: '/' }, { name: 'San Blas', path }]),
  ...(d.faq.length ? [faqPage(d.faq)] : []),
];
const seasonHref = localizePath('/season-2025-26/', locale);
---
<PageLayout title={d.seoTitle ?? d.title} description={d.metaDescription ?? d.description} path={path} availableLocales={availableLocales}>
  <Fragment slot="head">{schemas.map((s) => <JsonLd schema={s} />)}</Fragment>

  <header class="relative isolate overflow-hidden bg-ocean-950">
    {d.heroImage && (
      <Image src={d.heroImage} alt={d.title} width={1900} height={1050} widths={[640, 1024, 1900]} sizes="100vw" priority class="absolute inset-0 -z-10 h-full w-full object-cover opacity-55" />
    )}
    <div class="absolute inset-0 -z-10 bg-gradient-to-t from-ocean-950 via-ocean-950/55 to-transparent"></div>
    <div class="mx-auto flex min-h-[60vh] max-w-5xl flex-col justify-end px-4 py-16 sm:px-6">
      <p class="coords text-ocean-300">San Blas · Guna Yala · Panama</p>
      <h1 class="mt-3 max-w-3xl font-display text-4xl leading-tight text-sand-50 sm:text-6xl">{d.title}</h1>
      {d.lead && <p class="mt-4 max-w-2xl text-lg text-sand-100/90">{d.lead}</p>}
      <a href={seasonHref} class="mt-8 inline-block w-fit rounded-full bg-coral-500 px-7 py-3 font-semibold text-white transition hover:bg-coral-400">{t('cta.book')}</a>
    </div>
  </header>

  <div class="mx-auto max-w-5xl px-4 py-14 sm:px-6">
    <article class="max-w-3xl"><Prose entry={entry} /></article>

    <section class="mt-14">
      <h2 class="font-display text-2xl text-ocean-950">{t('home.activitiesTitle')}</h2>
      <div class="mt-6 grid gap-5 sm:grid-cols-2 lg:grid-cols-4">
        {cards.map((c) => (
          <a href={localizePath(`/panama/san-blas/${c.slug}/`, locale)} class="group relative overflow-hidden rounded-2xl bg-ocean-100 ring-1 ring-ocean-950/5 transition hover:ring-ocean-300">
            <div class="aspect-[4/3] overflow-hidden">
              {c.hero && <Image src={c.hero} alt={c.title} width={520} height={390} class="h-full w-full object-cover transition duration-700 group-hover:scale-105" />}
            </div>
            <div class="p-4"><h3 class="font-display text-lg text-ocean-950">{c.title}</h3></div>
          </a>
        ))}
      </div>
    </section>

    {d.faq.length > 0 && (
      <section class="mt-14 max-w-3xl">
        <h2 class="font-display text-2xl text-ocean-950">{t('trip.faq')}</h2>
        <FaqAccordion faq={d.faq} />
      </section>
    )}

    <div class="mt-14 flex flex-wrap gap-3">
      <a href={seasonHref} class="rounded-full bg-ocean-700 px-6 py-3 font-semibold text-sand-50 transition hover:bg-ocean-600">{t('cta.book')}</a>
      <a href={WHATSAPP_URL} target="_blank" rel="noopener" class="rounded-full border border-ocean-300 px-6 py-3 font-semibold text-ocean-700 transition hover:bg-ocean-100">{t('cta.whatsapp')}</a>
    </div>
  </div>
</PageLayout>
