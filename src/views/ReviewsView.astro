---
import { render } from 'astro:content';
import PageLayout from '../layouts/PageLayout.astro';
import PageHero from '../components/PageHero.astro';
import JsonLd from '../components/jsonld/JsonLd.astro';
import YouTubeEmbed from '../components/YouTubeEmbed.astro';
import { useTranslations, defaultLocale, type Locale } from '../i18n/ui';
import { entriesForLocale, entryForLocale, slugOf } from '../lib/content';
import { translationToHtml } from '../lib/format';
import googleReviews from '../data/google-reviews.json';

const g = googleReviews as { rating: number | null; count: number; mapsUri: string | null; reviews: { author: string; photo: string | null; profileUrl: string | null; rating: number; text: string; when: string; lang?: string | null; translations?: Record<string, string> }[] };
const hasGoogle = g.reviews.length > 0;

const { locale } = Astro.props as { locale: Locale };
const t = useTranslations(locale);

// Trustpilot TrustBox (free official "Review Carousel" widget) — business unit
// for ikigaisailing.com (TrustScore 4.6 / 24 reviews). data-locale maps the page
// language to Trustpilot's format; sk falls back to en-US (not a widget locale).
const TRUSTPILOT_BUID = '5fe0cf3580728900010a6211';
const TP_LOCALE: Record<Locale, string> = { en: 'en-US', it: 'it-IT', es: 'es-ES', fr: 'fr-FR', sk: 'en-US' };
const intro = await entryForLocale('pages', 'reviews', locale);
const testimonials = await entriesForLocale('testimonials', locale);

// video testimonials (YouTube) from the original site
const VIDEO_IDS = ['2HmfoUGScIg', 'HNpH5hnRjCY', 'htM6nco7BAo', 'IkmB7J0ZdGI', 'oYizauLg644', 'W6qp-Fp1V-8'];

const cards = await Promise.all(
  testimonials.map(async (item) => {
    const { Content } = await render(item);
    const translated = item.data.locale !== locale ? item.data.translations?.[locale] : undefined;
    return { item, slug: slugOf(item), Content, translated };
  }),
);

const reviewSchema = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  '@id': `${Astro.site!.origin}/#organization`,
  review: testimonials.map((tm) => ({
    '@type': 'Review',
    author: { '@type': 'Person', name: tm.data.author },
    reviewBody: tm.body?.slice(0, 400),
    ...(tm.data.rating ? { reviewRating: { '@type': 'Rating', ratingValue: tm.data.rating } } : {}),
  })),
};
---
<PageLayout title={`${t('nav.reviews')} — Ikigai Sailing`} description={intro?.data.description ?? 'What guests say about sailing aboard Ikigai.'} path="/reviews/">
  <JsonLd slot="head" schema={reviewSchema} />
  <PageHero eyebrow="Logbook" title={intro?.data.title ?? t('nav.reviews')} lead={intro?.data.description} />

  {/* video testimonials */}
  <section class="bg-ocean-950 py-14 text-sand-50">
    <div class="mx-auto max-w-6xl px-4 sm:px-6">
      <p class="coords mb-6 text-ocean-300">On camera</p>
      <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
        {VIDEO_IDS.map((id) => <YouTubeEmbed id={id} title="Guest video review" />)}
      </div>
    </div>
  </section>

  {/* external reviews CTAs */}
  <section class="bg-sand-50 pt-12 text-center">
    <div class="flex flex-wrap items-center justify-center gap-3">
      <a
        href="https://www.trustpilot.com/review/ikigaisailing.com"
        target="_blank"
        rel="noopener"
        class="inline-flex items-center gap-2 rounded-full bg-[#00b67a] px-6 py-3 font-semibold text-white shadow-sm transition hover:brightness-105"
      >
        <svg class="h-5 w-5" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="m12 2 2.95 6.7 7.05.62-5.32 4.67 1.6 6.99L12 17.3 5.72 21l1.6-6.99L2 9.32l7.05-.62L12 2Z"/></svg>
        {t('reviews.external')}
        <span aria-hidden="true">↗</span>
      </a>
      <a
        href="https://www.google.com/maps?cid=15753278920699617280"
        target="_blank"
        rel="noopener"
        class="inline-flex items-center gap-2 rounded-full bg-white px-6 py-3 font-semibold text-ocean-950 shadow-sm ring-1 ring-ocean-950/10 transition hover:bg-sand-100"
      >
        <svg class="h-5 w-5" viewBox="0 0 24 24" aria-hidden="true"><path fill="#4285F4" d="M23.5 12.3c0-.8-.1-1.6-.2-2.3H12v4.5h6.5a5.6 5.6 0 0 1-2.4 3.6v3h3.9c2.3-2.1 3.5-5.2 3.5-8.8Z"/><path fill="#34A853" d="M12 24c3.2 0 6-1.1 8-3l-3.9-3a7.2 7.2 0 0 1-10.7-3.8H1.3v3.1A12 12 0 0 0 12 24Z"/><path fill="#FBBC05" d="M5.4 14.2a7.2 7.2 0 0 1 0-4.6V6.5H1.3a12 12 0 0 0 0 11l4.1-3.3Z"/><path fill="#EA4335" d="M12 4.8c1.8 0 3.3.6 4.6 1.8l3.4-3.4A12 12 0 0 0 1.3 6.5l4.1 3.1A7.2 7.2 0 0 1 12 4.8Z"/></svg>
        {t('reviews.google')}
        <span aria-hidden="true">↗</span>
      </a>
    </div>
  </section>

  {/* live Google reviews (Places API — shows once GOOGLE_MAPS_API_KEY + GOOGLE_PLACE_ID are set) */}
  {hasGoogle && (
    <section class="bg-sand-50 pt-12">
      <div class="mx-auto max-w-6xl px-4 sm:px-6">
        <div class="flex flex-wrap items-end justify-between gap-3">
          <p class="coords text-ocean-600">Live on Google</p>
          {g.rating != null && (
            <p class="flex items-center gap-2 text-sm text-ink-soft">
              <span class="font-display text-2xl text-ocean-950">{g.rating.toFixed(1)}</span>
              <span class="text-coral-500">{'★★★★★'}</span>
              <span>· {g.count} {t('nav.reviews').toLowerCase()}</span>
            </p>
          )}
        </div>
        <div class="mt-6 grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
          {g.reviews.map((r, i) => {
            const tr = r.translations?.[locale];
            const canTranslate = !!tr && (r.lang || 'en').slice(0, 2) !== locale;
            return (
            <figure class="flex flex-col rounded-2xl border border-ocean-950/10 bg-sand-100 p-6">
              <div class="text-coral-500" aria-label={`${r.rating} stars`}>{'★'.repeat(Math.round(r.rating))}</div>
              <blockquote class="prose-ikigai mt-3 flex-1 text-[0.95rem]">
                <div data-orig={`g${i}`} set:html={translationToHtml(r.text)} />
                {canTranslate && <div data-trans={`g${i}`} hidden set:html={translationToHtml(tr!)} />}
              </blockquote>
              <figcaption class="mt-4 flex items-center gap-3 border-t border-ocean-950/5 pt-3">
                {r.photo && <img src={r.photo} alt="" width="32" height="32" loading="lazy" class="h-8 w-8 rounded-full object-cover" referrerpolicy="no-referrer" />}
                <div class="flex-1">
                  <p class="font-semibold text-ocean-950">{r.author}</p>
                  {r.when && <p class="coords text-ocean-600">{r.when}</p>}
                </div>
                {canTranslate && <button class="shrink-0 text-xs font-medium text-ocean-600 underline underline-offset-2 hover:text-ocean-800" data-toggle={`g${i}`}>{t('reviews.translated')}</button>}
              </figcaption>
            </figure>
            );
          })}
        </div>
      </div>
    </section>
  )}

  {/* live Trustpilot reviews — free official TrustBox (Review Carousel), loaded only on this page */}
  <section class="bg-sand-50 pt-12">
    <div class="mx-auto max-w-6xl px-4 sm:px-6">
      <p class="coords mb-5 text-ocean-600">Live on Trustpilot</p>
      {/* TrustBox widget - Review Carousel */}
      <div
        class="trustpilot-widget"
        data-locale={TP_LOCALE[locale]}
        data-template-id="53aa8912dec7e10d38f59f36"
        data-businessunit-id={TRUSTPILOT_BUID}
        data-style-height="240px"
        data-style-width="100%"
        data-stars="4,5"
      >
        <a href="https://www.trustpilot.com/review/ikigaisailing.com" target="_blank" rel="noopener">Trustpilot</a>
      </div>
      {/* End TrustBox widget */}
    </div>
  </section>

  {/* written guest letters — labelled divider sets these apart from the live Google block */}
  <div class="mx-auto max-w-6xl px-4 py-14 sm:px-6">
    <div class="mb-8 flex items-center gap-4">
      <span class="coords whitespace-nowrap text-ocean-600">{t('reviews.guests')}</span>
      <span class="h-px flex-1 bg-ocean-950/10"></span>
    </div>
    <div class="columns-1 gap-6 sm:columns-2 lg:columns-3 [&>*]:mb-6">
      {cards.map(({ item, slug, Content, translated }, i) => (
        <figure id={slug} class="scroll-mt-28 break-inside-avoid rounded-2xl bg-sand-100 p-6 ring-1 ring-ocean-950/5 target:ring-2 target:ring-coral-400">
          {/* clamped to a uniform height so one long letter can't dwarf the column; expands on click or when deep-linked (#slug) */}
          <blockquote class="testimonial-clamp prose-ikigai text-[0.95rem]">
            <div data-orig={i}><Content /></div>
            {translated && <div data-trans={i} hidden set:html={translationToHtml(translated)} />}
          </blockquote>
          <button class="review-more mt-2 hidden text-xs font-medium text-ocean-600 underline underline-offset-2 hover:text-ocean-800" data-more={i} data-more-label={t('reviews.more')} data-less-label={t('reviews.less')}>{t('reviews.more')}</button>
          <figcaption class="mt-4 flex items-center justify-between border-t border-ocean-950/10 pt-3">
            <div>
              <p class="font-semibold text-ocean-950">{item.data.author}</p>
              {item.data.origin && <p class="coords text-ocean-600">{item.data.origin}</p>}
            </div>
            {translated && <button class="text-xs font-medium text-ocean-600 underline underline-offset-2" data-toggle={i}>{t('reviews.translated')}</button>}
          </figcaption>
        </figure>
      ))}
    </div>
  </div>

  <script>
    // Show the "Read more" button only when a card actually overflows its clamp,
    // and keep it in sync after a translation toggle (translated text differs in length).
    function refreshMore(card: Element | null) {
      const clamp = card?.querySelector<HTMLElement>('.testimonial-clamp');
      const btn = card?.querySelector<HTMLButtonElement>('[data-more]');
      if (!clamp || !btn) return;
      const open = clamp.classList.contains('testimonial-clamp--open');
      const overflowing = open || clamp.scrollHeight - clamp.clientHeight > 4;
      btn.classList.toggle('hidden', !overflowing);
    }
    function bindExpand() {
      document.querySelectorAll<HTMLButtonElement>('[data-more]').forEach((btn) => {
        const card = btn.closest('figure');
        refreshMore(card);
        if (btn.dataset.bound) return;
        btn.dataset.bound = '1';
        const clamp = card?.querySelector<HTMLElement>('.testimonial-clamp');
        btn.addEventListener('click', () => {
          const open = clamp?.classList.toggle('testimonial-clamp--open');
          btn.textContent = open ? btn.dataset.lessLabel! : btn.dataset.moreLabel!;
        });
      });
    }
    document.addEventListener('astro:page-load', bindExpand);

    // Re-bind on every (View Transitions) navigation, not just first load —
    // otherwise the toggle is dead when /reviews/ is reached via client-side nav.
    function bindToggles() {
      document.querySelectorAll<HTMLButtonElement>('[data-toggle]').forEach((btn) => {
        if (btn.dataset.bound) return;
        btn.dataset.bound = '1';
        const card = btn.closest('figure');
        const i = btn.dataset.toggle;
        const orig = card?.querySelector<HTMLElement>(`[data-orig="${i}"]`);
        const trans = card?.querySelector<HTMLElement>(`[data-trans="${i}"]`);
        let showing = false;
        btn.addEventListener('click', () => {
          showing = !showing;
          if (orig) orig.hidden = showing;
          if (trans) trans.hidden = !showing;
          refreshMore(card); // text length changed — re-evaluate the clamp
        });
      });
    }
    document.addEventListener('astro:page-load', bindToggles);

    // A review deep-linked (#slug) from the homepage rail: scroll to it, flash it,
    // and expand it in full — matching the owner's "extended only when with #" ask.
    function flash() {
      const el = location.hash && document.querySelector(location.hash);
      if (!el) return;
      const clamp = el.querySelector?.('.testimonial-clamp');
      const btn = el.querySelector?.('[data-more]') as HTMLButtonElement | null;
      if (clamp) {
        clamp.classList.add('testimonial-clamp--open');
        if (btn) { btn.classList.remove('hidden'); btn.textContent = btn.dataset.lessLabel!; }
      }
      el.scrollIntoView({ block: 'center' });
      el.classList.add('ring-2', 'ring-coral-400');
    }
    document.addEventListener('astro:page-load', flash);

    // Trustpilot TrustBox: load the official bootstrap once, then (re)render the
    // widget on every page-load so it also works when /reviews/ is reached via
    // View Transitions (the bootstrap only auto-inits on a full document load).
    function renderTrustpilot() {
      const el = document.querySelector('.trustpilot-widget');
      if (!el) return; // not on the reviews page
      const TP = (window as any).Trustpilot;
      if (TP) { TP.loadFromElement(el, true); return; }
      if (document.getElementById('tp-bootstrap')) return; // already loading
      const s = document.createElement('script');
      s.id = 'tp-bootstrap';
      s.async = true;
      s.src = 'https://widget.trustpilot.com/bootstrap/v5/tp.widget.bootstrap.min.js';
      s.onload = renderTrustpilot;
      document.head.appendChild(s);
    }
    document.addEventListener('astro:page-load', renderTrustpilot);
  </script>
</PageLayout>
