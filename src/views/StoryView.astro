---
/** Dedicated, designed Story page: hero + lead + milestone timeline + founder's narrative. */
import { Image } from 'astro:assets';
import PageLayout from '../layouts/PageLayout.astro';
import SectionHeading from '../components/SectionHeading.astro';
import Timeline from '../components/Timeline.astro';
import Prose from '../components/Prose.astro';
import Gallery from '../components/Gallery.astro';
import WhatsAppButton from '../components/WhatsAppButton.astro';
import JsonLd from '../components/jsonld/JsonLd.astro';
import { useTranslations, localizePath, defaultLocale, type Locale } from '../i18n/ui';
import { entryForLocale } from '../lib/content';
import { breadcrumbs } from '../lib/schema';

const { locale } = Astro.props as { locale: Locale };
const t = useTranslations(locale);
const entry = await entryForLocale('pages', 'story', locale);
if (!entry) return Astro.redirect('/404/');
const d = entry.data;
const site = Astro.site!.origin;
const crumb = breadcrumbs(site, locale, [
  { name: 'Ikigai Sailing', path: '/' },
  { name: d.title, path: '/story/' },
]);
---

<PageLayout title={d.title} description={d.description} path="/story/">
  <JsonLd slot="head" schema={crumb} />

  {/* hero */}
  <header class="relative isolate overflow-hidden bg-ocean-950">
    {d.heroImage && (
      <Image src={d.heroImage} alt={d.title} width={1800} height={900} widths={[640, 1024, 1800]} sizes="100vw" loading="eager" class="absolute inset-0 -z-10 h-full w-full object-cover opacity-50" />
    )}
    <div class="absolute inset-0 -z-10 bg-gradient-to-t from-ocean-950 via-ocean-950/50 to-transparent"></div>
    <div class="mx-auto flex min-h-[56vh] max-w-4xl flex-col justify-end px-4 py-16 sm:px-6">
      <p class="coords text-ocean-300">{t('nav.story')}</p>
      <h1 class="mt-3 font-display text-4xl leading-tight text-sand-50 sm:text-5xl">{d.title}</h1>
      {d.lead && <p class="mt-4 max-w-2xl text-lg text-sand-100/90">{d.lead}</p>}
    </div>
  </header>

  {/* timeline */}
  {d.timeline.length > 0 && (
    <section class="bg-sand-50 py-20">
      <div class="mx-auto max-w-5xl px-4 sm:px-6">
        <SectionHeading eyebrow={t('nav.story')} title={d.title} align="center" />
        <div class="mt-14">
          <Timeline entries={d.timeline} />
        </div>
      </div>
    </section>
  )}

  {/* founder's narrative — presented as a quote from Luca */}
  <section class="bg-sand-100 py-20">
    <div class="mx-auto max-w-3xl px-4 sm:px-6">
      <figure class="relative rounded-3xl bg-sand-50 p-7 ring-1 ring-ocean-950/5 sm:p-10">
        <span aria-hidden="true" class="pointer-events-none absolute left-5 top-1 select-none font-display text-7xl leading-none text-ocean-200 sm:left-8">&ldquo;</span>
        <blockquote class="relative">
          <Prose entry={entry} />
        </blockquote>
        <figcaption class="mt-6 flex items-center gap-3 border-t border-ocean-950/5 pt-5">
          <span class="grid h-9 w-9 place-items-center rounded-full bg-ocean-700 font-display text-sand-50">L</span>
          <span class="coords text-sm font-semibold uppercase tracking-wide text-ocean-700">{t('story.narrator')}</span>
        </figcaption>
      </figure>
    </div>
  </section>

  {/* gallery */}
  {d.gallery.length > 0 && (
    <section class="bg-sand-50 py-16">
      <div class="mx-auto max-w-6xl px-4 sm:px-6">
        <p class="coords mb-6 text-ocean-600">{t('trip.gallery')}</p>
        <Gallery images={d.gallery} alt={d.title} />
      </div>
    </section>
  )}

  {/* CTA */}
  <section class="bg-ocean-900 py-16 text-center text-sand-50">
    <div class="mx-auto max-w-2xl px-4">
      <h2 class="font-display text-2xl sm:text-3xl">{t('contact.title')}</h2>
      <p class="mx-auto mt-3 max-w-md text-sand-100/80">{t('contact.whatsappLead')}</p>
      <div class="mt-7 flex flex-wrap justify-center gap-3">
        <a href={localizePath('/trips/', locale)} class="rounded-full bg-coral-500 px-6 py-3 font-semibold text-sand-50 transition hover:bg-coral-400">{t('cta.discoverTrips')}</a>
        <WhatsAppButton />
      </div>
    </div>
  </section>
</PageLayout>
