---
import { Image } from 'astro:assets';
import PageLayout from '../layouts/PageLayout.astro';
import PageHero from '../components/PageHero.astro';
import SectionHeading from '../components/SectionHeading.astro';
import TripCard from '../components/TripCard.astro';
import Prose from '../components/Prose.astro';
import WhatsAppButton from '../components/WhatsAppButton.astro';
import { useTranslations, localizePath, type Locale } from '../i18n/ui';
import { entriesForLocale, entryForLocale, slugOf } from '../lib/content';

const { locale } = Astro.props as { locale: Locale };
const t = useTranslations(locale);
const trips = (await entriesForLocale('trips', locale)).sort((a, b) => a.data.order - b.data.order);
const intro = await entryForLocale('pages', 'trips', locale);

// Flagship full experience headlines the page; the rest split into open boarding
// vs. members-only ("by invitation") voyages.
const featured = trips.find((tr) => slugOf(tr) === '10-days-on-board') ?? trips[0];
const rest = trips.filter((tr) => tr !== featured);
const bookable = rest.filter((tr) => !tr.data.membersOnly);
const members = rest.filter((tr) => tr.data.membersOnly);

const fd = featured.data;
const featuredHref = localizePath(`/trips/${slugOf(featured)}/`, locale);
---
<PageLayout title={intro?.data.seoTitle ?? `${t('nav.trips')} — Ikigai Sailing`} description={intro?.data.metaDescription ?? intro?.data.description ?? 'Boarding options aboard the Catana 47 Ikigai.'} path="/trips/">
  <PageHero eyebrow={t('home.tripsEyebrow')} title={intro?.data.title ?? t('nav.trips')} lead={intro?.data.description} />

  <!-- Flagship featured voyage -->
  <section class="relative overflow-hidden bg-ocean-950 text-sand-50">
    {fd.heroImage && (
      <Image
        src={fd.heroImage}
        alt=""
        width={1600}
        height={1000}
        class="absolute inset-0 h-full w-full object-cover opacity-30"
      />
    )}
    <div class="absolute inset-0 bg-gradient-to-r from-ocean-950 via-ocean-950/85 to-ocean-950/40"></div>
    <div class="relative mx-auto grid max-w-6xl gap-10 px-4 py-16 sm:px-6 sm:py-20 lg:grid-cols-[1.1fr_0.9fr] lg:items-center">
      <div>
        <p class="coords mb-4 flex items-center gap-2 text-ocean-300">
          <span class="inline-block h-px w-6 bg-current opacity-60"></span>{fd.location}
        </p>
        <h2 class="font-display text-4xl leading-tight tracking-[-0.015em] sm:text-5xl">{fd.title}</h2>
        <p class="mt-5 max-w-xl text-lg leading-relaxed text-sand-50/80">{fd.description}</p>
        <div class="mt-8 flex flex-wrap items-center gap-x-8 gap-y-3">
          <div>
            <span class="coords block text-ocean-300">{t('trip.duration')}</span>
            <span class="font-display text-xl">{fd.duration}</span>
          </div>
          {fd.price != null && (
            <div>
              <span class="coords block text-ocean-300">{t('trip.price')}</span>
              <span class="font-display text-xl">€{fd.price.toLocaleString()}</span>
            </div>
          )}
        </div>
        <div class="mt-9 flex flex-wrap items-center gap-4">
          {fd.price != null && (
            <button
              data-add-package
              data-sku={slugOf(featured)}
              data-name={fd.title}
              data-price={fd.price}
              class="inline-flex items-center gap-2 rounded-full bg-coral-500 px-7 py-3 font-semibold text-white shadow-lg shadow-ocean-950/30 transition hover:bg-coral-400"
            >
              {t('cart.add')}
            </button>
          )}
          <a href={featuredHref} class="inline-flex items-center gap-1.5 font-semibold text-sand-50 underline-offset-4 transition hover:text-ocean-300 hover:underline">
            {t('cta.readMore')} <span aria-hidden="true">→</span>
          </a>
        </div>
      </div>
    </div>
  </section>

  <div class="mx-auto max-w-6xl px-4 py-16 sm:px-6 sm:py-20">
    <!-- Open boarding options -->
    <SectionHeading eyebrow={t('home.tripsEyebrow')} title={t('home.tripsTitle')} />
    <div class="mt-8 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {bookable.map((trip) => <TripCard trip={trip} locale={locale} />)}
    </div>

    {members.length > 0 && (
      <div class="mt-20">
        <SectionHeading eyebrow={t('trip.membersOnly')} title={t('trips.invitation')} />
        <p class="mt-4 max-w-2xl text-ink-soft">{t('trips.invitationLead')}</p>
        <div class="mt-8 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
          {members.map((trip) => <TripCard trip={trip} locale={locale} />)}
        </div>
      </div>
    )}

    {intro && <article class="mt-20 border-t border-ocean-950/5 pt-12"><Prose entry={intro} /></article>}
  </div>

  <!-- WhatsApp CTA band -->
  <section class="bg-coral-500 text-white">
    <div class="mx-auto flex max-w-4xl flex-col items-center gap-6 px-4 py-16 text-center sm:px-6">
      <h2 class="font-display text-3xl leading-tight tracking-[-0.015em] sm:text-4xl">{t('contact.whatsappLead')}</h2>
      <WhatsAppButton />
    </div>
  </section>
</PageLayout>
