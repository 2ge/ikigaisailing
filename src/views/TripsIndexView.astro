---
import { getCollection } from 'astro:content';
import PageLayout from '../layouts/PageLayout.astro';
import PageHero from '../components/PageHero.astro';
import TripCard from '../components/TripCard.astro';
import Prose from '../components/Prose.astro';
import { useTranslations, defaultLocale, type Locale } from '../i18n/ui';
import { entriesForLocale, entryForLocale } from '../lib/content';

const { locale } = Astro.props as { locale: Locale };
const t = useTranslations(locale);
const trips = (await entriesForLocale('trips', locale)).sort((a, b) => a.data.order - b.data.order);
const intro = await entryForLocale('pages', 'trips', locale);
---
<PageLayout title={`${t('nav.trips')} — Ikigai Sailing`} description={intro?.data.description ?? 'Boarding options aboard the Catana 47 Ikigai.'} path="/trips/">
  <PageHero eyebrow={t('home.destinations')} title={intro?.data.title ?? t('nav.trips')} lead={intro?.data.description} />
  <div class="mx-auto max-w-6xl px-4 py-14 sm:px-6">
    <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {trips.map((trip) => <TripCard trip={trip} locale={locale} />)}
    </div>
    {intro && <article class="mt-14"><Prose entry={intro} /></article>}
  </div>
</PageLayout>
