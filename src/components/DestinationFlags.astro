---
/** Flag grid of destinations reached. Flag alt is empty (decorative) — the
 *  country name is already shown as text, so screen readers + copy don't read it twice. */
import { Image } from 'astro:assets';

const flagMods = import.meta.glob<{ default: ImageMetadata }>(
  '../assets/pages/home/Flag_*.{png,avif,svg}',
  { eager: true },
);

function nameFromPath(p: string): string {
  const m = p.match(/Flag_of_(?:the_)?([^.]+?)\.svg/);
  return m ? decodeURIComponent(m[1]).replace(/_/g, ' ') : '';
}

// dedupe by country name (drops the stray second "Venezuela" variant)
const byName = new Map<string, ImageMetadata>();
for (const [p, mod] of Object.entries(flagMods)) {
  const name = nameFromPath(p);
  if (name && !byName.has(name)) byName.set(name, mod.default);
}
const flags = [...byName.entries()].sort((a, b) => a[0].localeCompare(b[0]));
---

<ul class="flex flex-wrap justify-center gap-2.5">
  {flags.map(([name, img]) => (
    <li class="flex items-center gap-2 rounded-full bg-sand-50 py-1.5 pl-1.5 pr-3.5 ring-1 ring-ocean-950/5">
      <Image src={img} alt="" width={28} height={20} class="h-5 w-7 rounded-sm object-cover shadow-sm" />
      <span class="text-sm text-ink-soft">{name}</span>
    </li>
  ))}
</ul>
