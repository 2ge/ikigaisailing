---
/** Inner-page hero band: eyebrow coords + display title + optional lead. */
interface Props {
  eyebrow?: string;
  title: string;
  lead?: string;
}
const { eyebrow, title, lead } = Astro.props;
---
<header class="border-b border-ocean-950/5 bg-sand-100">
  <div class="mx-auto max-w-4xl px-4 py-16 sm:px-6 sm:py-20">
    {eyebrow && <p class="coords mb-3 text-ocean-600">{eyebrow}</p>}
    <h1 class="font-display text-4xl leading-tight tracking-[-0.015em] text-ocean-950 sm:text-5xl">{title}</h1>
    {lead && <p class="mt-5 max-w-2xl text-lg text-ink-soft">{lead}</p>}
  </div>
</header>
