---
/**
 * Year-grouped voyage logbook: a continuous vertical timeline of anchorages.
 * Each year opens a section; legs hang off the line. The current position
 * ("now") is highlighted. Fully localised via the page's `voyage` frontmatter.
 */
interface Leg { when: string; place: string; note: string; now?: boolean }
interface Year { year: string; title: string; legs: Leg[] }
interface Props { years: Year[]; nowLabel?: string }
const { years, nowLabel = 'You are here' } = Astro.props;
---

<div class="relative mx-auto max-w-3xl">
  {years.map((y) => (
    <section class="relative">
      {/* year header */}
      <header class="flex items-baseline gap-4 pb-6 pt-10 first:pt-0">
        <span class="font-display text-4xl leading-none text-ocean-300 sm:text-5xl">{y.year}</span>
        <span class="font-display text-lg text-ocean-950 sm:text-xl">{y.title}</span>
      </header>

      {/* legs on a vertical line */}
      <ol class="relative ml-2 border-l-2 border-ocean-200/80 pl-8">
        {y.legs.map((leg, i) => (
          <li class="reveal relative pb-8 last:pb-2" style={`animation-delay:${i * 60}ms`}>
            <span
              class:list={[
                'absolute -left-[2.55rem] top-1 grid place-items-center rounded-full ring-4 ring-sand-50',
                leg.now ? 'h-7 w-7 bg-coral-500' : 'h-5 w-5 bg-ocean-400',
              ]}
            >
              {leg.now ? (
                <span class="h-2 w-2 animate-ping rounded-full bg-sand-50"></span>
              ) : (
                <span class="h-1.5 w-1.5 rounded-full bg-sand-50"></span>
              )}
            </span>
            <div class="flex flex-wrap items-baseline gap-x-2.5">
              <span class="coords text-xs uppercase tracking-wide text-ocean-600">{leg.when}</span>
              <h3 class="font-display text-lg text-ocean-950">{leg.place}</h3>
              {leg.now && (
                <span class="rounded-full bg-coral-100 px-2 py-0.5 text-[0.7rem] font-semibold uppercase tracking-wide text-coral-700">{nowLabel}</span>
              )}
            </div>
            <p class="mt-1 text-[0.95rem] leading-relaxed text-ink-soft">{leg.note}</p>
          </li>
        ))}
      </ol>
    </section>
  ))}
</div>
