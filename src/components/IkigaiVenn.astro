---
/**
 * The classic Ikigai diagram — four overlapping circles (what we love /
 * are good at / the world needs / we can be paid for), their pairwise
 * overlaps (passion · mission · profession · vocation), and Ikigai at the
 * centre. Localised via i18n. Full diagram on sm+; a stacked legend on mobile.
 */
import { useTranslations, getLocaleFromUrl } from '../i18n/ui';
const t = useTranslations(getLocaleFromUrl(Astro.url));

const circles = [
  { label: t('ikigai.love'), cls: 'left-1/2 top-0 -translate-x-1/2', fill: 'bg-coral-400/45', lbl: 'top-[9%] left-1/2 -translate-x-1/2' },
  { label: t('ikigai.good'), cls: 'left-0 top-1/2 -translate-y-1/2', fill: 'bg-ocean-400/45', lbl: 'left-[7%] top-1/2 -translate-y-1/2' },
  { label: t('ikigai.needs'), cls: 'right-0 top-1/2 -translate-y-1/2', fill: 'bg-sand-400/55', lbl: 'right-[7%] top-1/2 -translate-y-1/2' },
  { label: t('ikigai.paid'), cls: 'bottom-0 left-1/2 -translate-x-1/2', fill: 'bg-ocean-600/45', lbl: 'bottom-[9%] left-1/2 -translate-x-1/2' },
];
// pairwise overlaps (petals)
const petals = [
  { label: t('ikigai.passion'), cls: 'left-[27%] top-[30%]' }, // love ∩ good
  { label: t('ikigai.mission'), cls: 'right-[27%] top-[30%]' }, // love ∩ needs
  { label: t('ikigai.profession'), cls: 'bottom-[30%] left-[27%]' }, // good ∩ paid
  { label: t('ikigai.vocation'), cls: 'bottom-[30%] right-[27%]' }, // needs ∩ paid
];
---

{/* full diagram — sm and up */}
<div class="mx-auto hidden aspect-square w-full max-w-2xl sm:block">
  <div class="relative h-full w-full" style="mix-blend-mode: normal;">
    {/* four overlapping circles (multiply so overlaps deepen) */}
    {circles.map((c) => (
      <div class:list={['absolute h-[62%] w-[62%] rounded-full mix-blend-multiply ring-1 ring-ocean-950/5', c.fill, c.cls]}></div>
    ))}
    {circles.map((c) => (
      <span class:list={['absolute z-[5] max-w-[22%] text-center text-sm font-semibold leading-tight text-ocean-950', c.lbl]}>{c.label}</span>
    ))}
    {/* petals */}
    {petals.map((p) => (
      <span class:list={['absolute -translate-x-1/2 -translate-y-1/2 font-display text-lg text-ocean-950', p.cls]}>{p.label}</span>
    ))}
    {/* centre */}
    <span class="absolute left-1/2 top-1/2 z-10 grid h-20 w-20 -translate-x-1/2 -translate-y-1/2 place-items-center rounded-full bg-coral-500 text-center text-sand-50 shadow-lg">
      <span><span class="block font-display text-base leading-none">生き甲斐</span><span class="coords mt-0.5 block text-[0.55rem]">Ikigai</span></span>
    </span>
  </div>
</div>

{/* mobile fallback — stacked cards */}
<div class="grid gap-4 sm:hidden">
  {[
    { t: t('ikigai.love'), b: t('ikigai.loveBody'), bg: 'bg-coral-400/15' },
    { t: t('ikigai.good'), b: t('ikigai.goodBody'), bg: 'bg-ocean-400/15' },
    { t: t('ikigai.needs'), b: t('ikigai.needsBody'), bg: 'bg-sand-400/20' },
    { t: t('ikigai.paid'), b: t('ikigai.paidBody'), bg: 'bg-ocean-700/15' },
  ].map((c) => (
    <div class:list={['rounded-2xl p-5 ring-1 ring-ocean-950/5', c.bg]}>
      <h3 class="font-display text-lg text-ocean-950">{c.t}</h3>
      <p class="mt-1.5 text-sm leading-relaxed text-ink-soft">{c.b}</p>
    </div>
  ))}
</div>
