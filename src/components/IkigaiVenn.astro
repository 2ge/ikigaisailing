---
/**
 * The classic Ikigai diagram — four overlapping circles (what we love /
 * are good at / the world needs / we can be paid for), their pairwise
 * overlaps (passion · mission · profession · vocation), and Ikigai at the
 * centre. Localised via i18n.
 *
 * Shown on ALL viewports. The long per-circle labels are desktop-only (they'd
 * overlap on a phone); on mobile the colour-keyed legend cards beneath the
 * diagram name each circle instead. Petals + centre scale down on mobile.
 */
import { useTranslations, getLocaleFromUrl } from '../i18n/ui';
const t = useTranslations(getLocaleFromUrl(Astro.url));

const circles = [
  { label: t('ikigai.love'), cls: 'left-1/2 top-0 -translate-x-1/2', fill: 'bg-coral-400/45', lbl: 'top-[9%] left-1/2 -translate-x-1/2' },
  { label: t('ikigai.good'), cls: 'left-0 top-1/2 -translate-y-1/2', fill: 'bg-ocean-400/45', lbl: 'left-[7%] top-1/2 -translate-y-1/2' },
  { label: t('ikigai.needs'), cls: 'right-0 top-1/2 -translate-y-1/2', fill: 'bg-sand-400/55', lbl: 'right-[7%] top-1/2 -translate-y-1/2' },
  { label: t('ikigai.paid'), cls: 'bottom-0 left-1/2 -translate-x-1/2', fill: 'bg-ocean-600/45', lbl: 'bottom-[9%] left-1/2 -translate-x-1/2' },
];
// pairwise overlaps (petals)
const petals = [
  { label: t('ikigai.passion'), cls: 'left-[27%] top-[30%]' }, // love ∩ good
  { label: t('ikigai.mission'), cls: 'right-[27%] top-[30%]' }, // love ∩ needs
  { label: t('ikigai.profession'), cls: 'bottom-[30%] left-[27%]' }, // good ∩ paid
  { label: t('ikigai.vocation'), cls: 'bottom-[30%] right-[27%]' }, // needs ∩ paid
];
---

{/* the diagram — all viewports (circle labels desktop-only; legend names them on mobile) */}
<div class="mx-auto aspect-square w-full max-w-md sm:max-w-2xl">
  <div class="relative h-full w-full">
    {/* four overlapping circles (multiply so overlaps deepen) */}
    {circles.map((c) => (
      <div class:list={['absolute h-[62%] w-[62%] rounded-full mix-blend-multiply ring-1 ring-ocean-950/5', c.fill, c.cls]}></div>
    ))}
    {/* per-circle labels — desktop only */}
    {circles.map((c) => (
      <span class:list={['absolute z-[5] hidden max-w-[22%] text-center text-sm font-semibold leading-tight text-ocean-950 sm:block', c.lbl]}>{c.label}</span>
    ))}
    {/* petals — pairwise overlaps (smaller on mobile) */}
    {petals.map((p) => (
      <span class:list={['absolute z-[5] max-w-[26%] -translate-x-1/2 -translate-y-1/2 text-center font-display text-[0.7rem] leading-tight text-ocean-950 sm:max-w-none sm:text-lg', p.cls]}>{p.label}</span>
    ))}
    {/* centre */}
    <span class="absolute left-1/2 top-1/2 z-10 grid h-16 w-16 -translate-x-1/2 -translate-y-1/2 place-items-center rounded-full bg-coral-500 text-center text-sand-50 shadow-lg sm:h-20 sm:w-20">
      <span><span class="block font-display text-sm leading-none sm:text-base">生き甲斐</span><span class="coords mt-0.5 block text-[0.5rem] sm:text-[0.55rem]">Ikigai</span></span>
    </span>
  </div>
</div>
