---
import { Image } from 'astro:assets';
import SectionHeading from './SectionHeading.astro';
import DestinationFlags from './DestinationFlags.astro';
import TripCard from './TripCard.astro';
import ActivityCard from './ActivityCard.astro';
import TestimonialRail from './TestimonialRail.astro';
import MapEmbed from './MapEmbed.astro';
import WhatsAppButton from './WhatsAppButton.astro';
import { useTranslations, localizePath, type Locale } from '../i18n/ui';
import { WHATSAPP_URL } from '../i18n/nav';
import { entriesForLocale } from '../lib/content';
import heroImg from '../assets/pages/home/IKIGAI-130-1.jpg';

interface Props { locale: Locale; }
const { locale } = Astro.props;
const t = useTranslations(locale);
const lp = (p: string) => localizePath(p, locale);

const trips = (await entriesForLocale('trips', locale)).sort((a, b) => a.data.order - b.data.order);
const activities = (await entriesForLocale('activities', locale))
  .sort((a, b) => a.data.order - b.data.order)
  .slice(0, 6);
const testimonials = (await entriesForLocale('testimonials', locale)).slice(0, 8);

const pillars = [
  { word: 'PASSION', body: t('home.pillarPassion') },
  { word: 'CALLING', body: t('home.pillarCalling') },
  { word: 'PROFESSION', body: t('home.pillarProfession') },
];
---

{/* HERO */}
<section class="relative isolate overflow-hidden bg-ocean-950">
  <Image src={heroImg} alt="The catamaran Ikigai at anchor in turquoise water" width={2000} height={1500} widths={[640, 1024, 1600, 2000]} sizes="100vw" priority class="absolute inset-0 -z-10 h-full w-full object-cover opacity-70" />
  <div class="absolute inset-0 -z-10 bg-gradient-to-t from-ocean-950 via-ocean-950/40 to-ocean-950/30"></div>
  <div class="mx-auto flex min-h-[88vh] max-w-6xl flex-col justify-end px-4 pb-16 pt-28 sm:px-6">
    <p class="coords reveal reveal-1 text-ocean-300">{t('home.heroCoords')}</p>
    <h1 class="reveal reveal-2 mt-4 max-w-3xl font-display text-5xl leading-[1.02] tracking-[-0.02em] text-sand-50 sm:text-7xl">{t('home.heroTitle')}</h1>
    <p class="reveal reveal-3 mt-6 max-w-xl text-lg text-sand-100/90">{t('home.heroLead')}</p>
    <div class="reveal reveal-4 mt-8 flex flex-wrap gap-3">
      <a href={lp('/panama/san-blas/')} class="rounded-full bg-coral-500 px-6 py-3 font-semibold text-sand-50 shadow-lg transition hover:bg-coral-400">{t('home.heroCtaSeason')}</a>
      <a href={WHATSAPP_URL} target="_blank" rel="noopener" class="rounded-full border border-sand-100/30 bg-ocean-950/30 px-6 py-3 font-semibold text-sand-50 backdrop-blur transition hover:bg-ocean-950/50">{t('cta.whatsapp')}</a>
    </div>
  </div>
</section>

{/* IKIGAI PILLARS */}
<section class="bg-sand-100 py-20">
  <div class="mx-auto max-w-6xl px-4 sm:px-6">
    <SectionHeading eyebrow={t('home.ikigaiEyebrow')} title={t('home.ikigaiTitle')} />
    <div class="mt-12 grid gap-px overflow-hidden rounded-2xl bg-ocean-950/10 sm:grid-cols-3">
      {pillars.map((p) => (
        <div class="bg-sand-50 p-8">
          <p class="coords text-ocean-600">{p.word}</p>
          <p class="mt-3 font-display text-xl leading-snug text-ocean-950">{p.body}</p>
        </div>
      ))}
    </div>
    <p class="mt-8 max-w-2xl text-ink-soft">
      {t('home.ikigaiBody')}
      <a href={lp('/ikigai/')} class="ml-1 font-semibold text-ocean-600 underline underline-offset-2">{t('home.ikigaiLink')} →</a>
    </p>
  </div>
</section>

{/* STATS + FLAGS */}
<section class="bg-ocean-950 py-20 text-sand-50">
  <div class="mx-auto max-w-6xl px-4 sm:px-6">
    <dl class="grid grid-cols-3 gap-2 text-center sm:gap-6">
      {[
        { n: '2022', l: t('home.statsSince') },
        { n: '20+', l: t('home.statsCountries') },
        { n: '10,000+', l: t('home.statsMiles') },
      ].map((s) => (
        <div>
          <dt class="font-display text-2xl text-ocean-300 sm:text-6xl">{s.n}</dt>
          <dd class="coords mt-2 text-sand-100/70">{s.l}</dd>
        </div>
      ))}
    </dl>
    <div class="chart-rule my-14 opacity-30"></div>
    <p class="coords mb-8 text-center text-ocean-300">{t('home.destinations')}</p>
    <DestinationFlags />
  </div>
</section>

{/* BOARDING OPTIONS */}
<section class="bg-sand-50 py-20">
  <div class="mx-auto max-w-6xl px-4 sm:px-6">
    <div class="flex flex-wrap items-end justify-between gap-4">
      <SectionHeading eyebrow={t('home.tripsEyebrow')} title={t('home.tripsTitle')} />
      <a href={lp('/trips/')} class="coords text-ocean-600 hover:text-ocean-800">{t('cta.discoverTrips')} →</a>
    </div>
    <div class="mt-12 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {trips.map((trip) => <TripCard trip={trip} locale={locale} />)}
    </div>
  </div>
</section>

{/* ACTIVITIES */}
<section class="bg-sand-100 py-20">
  <div class="mx-auto max-w-6xl px-4 sm:px-6">
    <div class="flex flex-wrap items-end justify-between gap-4">
      <SectionHeading eyebrow={t('home.activitiesEyebrow')} title={t('home.activitiesTitle')} />
      <a href={lp('/activities/')} class="coords text-ocean-600 hover:text-ocean-800">{t('cta.allActivities')} →</a>
    </div>
    <div class="mt-12 grid grid-cols-2 gap-4 sm:grid-cols-3 lg:grid-cols-6">
      {activities.map((activity) => <ActivityCard activity={activity} locale={locale} />)}
    </div>
  </div>
</section>

{/* ROUTE + MAP */}
<section class="bg-ocean-900 py-20 text-sand-50">
  <div class="mx-auto grid max-w-6xl items-center gap-10 px-4 sm:px-6 lg:grid-cols-2">
    <div>
      <SectionHeading eyebrow={t('home.routeEyebrow')} title={t('home.routeTitle')} light />
      <p class="mt-5 max-w-md text-sand-100/85">{t('home.routeBody')}</p>
      <a href={lp('/route/')} class="mt-6 inline-block rounded-full border border-sand-100/30 px-5 py-2.5 font-semibold text-sand-50 transition hover:bg-ocean-950/40">{t('home.routeCta')}</a>
    </div>
    <MapEmbed label={t('home.routeMapBtn')} />
  </div>
</section>

{/* TESTIMONIALS */}
<section class="bg-sand-50 py-20">
  <div class="mx-auto max-w-6xl px-4 sm:px-6">
    <div class="flex flex-wrap items-end justify-between gap-4">
      <SectionHeading eyebrow={t('home.logbook')} title={t('home.testimonialsTitle')} />
      <a href={lp('/reviews/')} class="coords text-ocean-600 hover:text-ocean-800">{t('cta.allReviews')} →</a>
    </div>
    <div class="mt-12"><TestimonialRail testimonials={testimonials} locale={locale} /></div>
  </div>
</section>

{/* CTA */}
<section class="bg-coral-500 py-20 text-center text-sand-50">
  <div class="mx-auto max-w-2xl px-4">
    <h2 class="font-display text-3xl sm:text-4xl">{t('home.ctaTitle')}</h2>
    <p class="mt-4 text-sand-50/90">{t('contact.whatsappLead')}</p>
    <WhatsAppButton class="mt-8" />
  </div>
</section>
