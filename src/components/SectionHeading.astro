---
/** Eyebrow + display heading with the nautical coordinate motif. */
interface Props {
  eyebrow?: string;
  title: string;
  align?: 'left' | 'center';
  light?: boolean;
}
const { eyebrow, title, align = 'left', light = false } = Astro.props;
---

<div class:list={[align === 'center' && 'text-center', 'max-w-2xl', align === 'center' && 'mx-auto']}>
  {eyebrow && (
    <p class:list={['coords mb-3 flex items-center gap-2', light ? 'text-ocean-300' : 'text-ocean-600', align === 'center' && 'justify-center']}>
      <span class="inline-block h-px w-6 bg-current opacity-60"></span>{eyebrow}
    </p>
  )}
  <h2 class:list={['font-display text-3xl leading-tight tracking-[-0.015em] sm:text-4xl', light ? 'text-sand-50' : 'text-ocean-950']}>
    {title}
  </h2>
</div>
