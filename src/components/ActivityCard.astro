---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import { localizePath, type Locale } from '../i18n/ui';
import { slugOf } from '../lib/content';

interface Props {
  activity: CollectionEntry<'activities'>;
  locale: Locale;
}
const { activity, locale } = Astro.props;
const d = activity.data;
const href = localizePath(`/activities/${slugOf(activity)}/`, locale);
---

<a href={href} class="group relative block aspect-[3/4] overflow-hidden rounded-2xl bg-ocean-900">
  {d.image && (
    <Image
      src={d.image}
      alt={d.title}
      width={420}
      height={560}
      class="h-full w-full object-cover opacity-85 transition duration-700 group-hover:scale-105 group-hover:opacity-100"
    />
  )}
  <div class="absolute inset-0 bg-gradient-to-t from-ocean-950/85 via-ocean-950/10 to-transparent"></div>
  <div class="absolute inset-x-0 bottom-0 p-4">
    <h3 class="font-display text-xl text-sand-50">{d.title}</h3>
    <p class="mt-1 line-clamp-2 text-sm text-sand-100/80">{d.summary}</p>
  </div>
</a>
