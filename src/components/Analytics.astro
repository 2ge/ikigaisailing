---
/**
 * Analytics — loaded OFF the critical path (requestIdleCallback) to protect LCP.
 * Per owner decision: keep GTM + Meta pixel AND add self-hosted umami in parallel.
 * IDs centralised here. Skipped entirely on dev / preview.
 */
const GTM_ID = 'GTM-MM7ZH8ZJ';
const META_PIXEL_ID = '936580528526004';
const UMAMI_SRC = import.meta.env.PUBLIC_UMAMI_SRC; // e.g. https://umami.2pu.net/script.js
const UMAMI_ID = import.meta.env.PUBLIC_UMAMI_ID;
const isProd = import.meta.env.PROD;
---

{isProd && (
  <script is:inline define:vars={{ GTM_ID, META_PIXEL_ID, UMAMI_SRC, UMAMI_ID }}>
    // Defer all third-party tags until the browser is idle — keeps them out of LCP.
    const boot = () => {
      // Google Tag Manager
      (function (w, d, s, l, i) {
        w[l] = w[l] || [];
        w[l].push({ 'gtm.start': Date.now(), event: 'gtm.js' });
        const f = d.getElementsByTagName(s)[0];
        const j = d.createElement(s);
        j.async = true;
        j.src = 'https://www.googletagmanager.com/gtm.js?id=' + i;
        f.parentNode.insertBefore(j, f);
      })(window, document, 'script', 'dataLayer', GTM_ID);

      // Meta Pixel
      !(function (f, b, e, v, n, t, s) {
        if (f.fbq) return;
        n = f.fbq = function () { n.callMethod ? n.callMethod.apply(n, arguments) : n.queue.push(arguments); };
        if (!f._fbq) f._fbq = n;
        n.push = n; n.loaded = true; n.version = '2.0'; n.queue = [];
        t = b.createElement(e); t.async = true; t.src = v;
        s = b.getElementsByTagName(e)[0]; s.parentNode.insertBefore(t, s);
      })(window, document, 'script', 'https://connect.facebook.net/en_US/fbevents.js');
      window.fbq('init', META_PIXEL_ID);
      window.fbq('track', 'PageView');

      // Self-hosted umami (privacy-friendly, parallel to GTM per owner)
      if (UMAMI_SRC && UMAMI_ID) {
        const u = document.createElement('script');
        u.async = true; u.defer = true; u.src = UMAMI_SRC;
        u.setAttribute('data-website-id', UMAMI_ID);
        document.head.appendChild(u);
      }
    };
    if ('requestIdleCallback' in window) requestIdleCallback(boot, { timeout: 4000 });
    else window.addEventListener('load', () => setTimeout(boot, 1200));
  </script>
  <noscript>
    <iframe src={`https://www.googletagmanager.com/ns.html?id=${GTM_ID}`} height="0" width="0" style="display:none;visibility:hidden"></iframe>
  </noscript>
)}
