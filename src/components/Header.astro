---
/**
 * Sticky header: logo, nav with dropdowns, language switcher, WhatsApp CTA,
 * mobile hamburger. Vanilla JS only (one tiny inline script).
 */
import { Image } from 'astro:assets';
import logo from '../assets/brand/logo.webp';
import gbFlag from '../assets/flags/gb.svg?raw';
import itFlag from '../assets/flags/it.svg?raw';
import esFlag from '../assets/flags/es.svg?raw';
import frFlag from '../assets/flags/fr.svg?raw';
import skFlag from '../assets/flags/sk.svg?raw';
import { useTranslations, localizePath, canonicalizePath, getLocaleFromUrl, locales, localeNames, type Locale } from '../i18n/ui';
import { mainNav, WHATSAPP_URL } from '../i18n/nav';

const flags: Record<Locale, string> = { en: gbFlag, it: itFlag, es: esFlag, fr: frFlag, sk: skFlag };

interface Props {
  /** locales this page exists in; the switcher only offers these (defaults to all) */
  availableLocales?: Locale[];
}
const { availableLocales } = Astro.props as Props;
const switchLocales = (availableLocales ?? [...locales]) as Locale[];

const locale = getLocaleFromUrl(Astro.url);
const t = useTranslations(locale);
// canonical (English) form of the current URL, so the switcher can re-localize
// it into every other locale's segments.
const basePath = canonicalizePath(Astro.url.pathname, locale);
const lp = (p: string) => localizePath(p, locale);
---

<header
  id="site-header"
  class="sticky top-0 z-50 border-b border-ocean-950/5 bg-sand-50/90 backdrop-blur-md"
>
  <div class="mx-auto flex h-[4.75rem] max-w-6xl items-center justify-between gap-4 px-4 sm:h-20 sm:px-6">
    <a href={lp('/')} class="flex shrink-0 items-center gap-2" aria-label={t('site.name')}>
      <Image src={logo} alt={t('site.name')} width={228} height={60} class="h-9 w-auto sm:h-11" loading="eager" />
    </a>

    <nav class="hidden items-center gap-1 lg:flex" aria-label="Main">
      {mainNav.map((item) =>
        item.children ? (
          <div class="group relative">
            <a
              href={lp(item.path)}
              class="flex items-center gap-1 rounded-full px-3 py-2 text-sm font-medium text-ink hover:bg-ocean-100"
            >
              {t(item.key)}
              <svg class="h-3 w-3 opacity-50" viewBox="0 0 12 12" fill="none" aria-hidden="true">
                <path d="M2.5 4.5L6 8l3.5-3.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" />
              </svg>
            </a>
            <div
              class="invisible absolute left-0 top-full min-w-48 translate-y-1 rounded-xl border border-ocean-950/5 bg-sand-50 p-1.5 opacity-0 shadow-lg shadow-ocean-950/5 transition-all duration-150 group-hover:visible group-hover:translate-y-0 group-hover:opacity-100 group-focus-within:visible group-focus-within:translate-y-0 group-focus-within:opacity-100"
            >
              {item.children.map((c) => (
                <a
                  href={lp(c.path)}
                  class="block rounded-lg px-3 py-2 text-sm text-ink-soft hover:bg-ocean-100 hover:text-ink"
                >
                  {t(c.key)}
                </a>
              ))}
            </div>
          </div>
        ) : (
          <a
            href={lp(item.path)}
            class="rounded-full px-3 py-2 text-sm font-medium text-ink hover:bg-ocean-100"
          >
            {t(item.key)}
          </a>
        )
      )}
    </nav>

    <div class="flex items-center gap-2">
      {/* language switcher */}
      <div class="group relative">
        <button
          class="coords flex items-center gap-1.5 rounded-full px-2.5 py-2 text-ink-soft hover:bg-ocean-100"
          aria-label={t('lang.switch')}
        >
          <span class="flag" set:html={flags[locale]} />
          <svg class="h-3 w-3 opacity-50" viewBox="0 0 12 12" fill="none" aria-hidden="true">
            <path d="M2.5 4.5L6 8l3.5-3.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" />
          </svg>
        </button>
        <div
          class="invisible absolute right-0 top-full translate-y-1 rounded-xl border border-ocean-950/5 bg-sand-50 p-1.5 opacity-0 shadow-lg shadow-ocean-950/5 transition-all duration-150 group-hover:visible group-hover:translate-y-0 group-hover:opacity-100 group-focus-within:visible group-focus-within:translate-y-0 group-focus-within:opacity-100"
        >
          {switchLocales.map((l) => (
            <a
              href={localizePath(basePath, l as Locale)}
              data-lang={l}
              class:list={[
                'flex items-center gap-2.5 rounded-lg px-3 py-1.5 text-sm hover:bg-ocean-100',
                l === locale ? 'font-semibold text-ocean-700' : 'text-ink-soft',
              ]}
              hreflang={l}
            >
              <span class="flag" set:html={flags[l as Locale]} />
              <span>{localeNames[l as Locale]}</span>
            </a>
          ))}
        </div>
      </div>

      <a
        href={lp('/contact/')}
        class="hidden rounded-full bg-ocean-700 px-4 py-2 text-sm font-semibold text-sand-50 shadow-sm transition hover:bg-ocean-600 sm:block"
      >
        {t('cta.contact')}
      </a>

      {/* mobile hamburger */}
      <button
        id="menu-toggle"
        class="rounded-full p-2 hover:bg-ocean-100 lg:hidden"
        aria-expanded="false"
        aria-controls="mobile-menu"
        aria-label="Menu"
      >
        <svg class="h-5 w-5" viewBox="0 0 20 20" fill="none" aria-hidden="true">
          <path d="M3 5h14M3 10h14M3 15h14" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" />
        </svg>
      </button>
    </div>
  </div>

  {/* mobile menu */}
  <div id="mobile-menu" class="hidden border-t border-ocean-950/5 lg:hidden">
    <nav class="mx-auto max-w-6xl space-y-1 px-4 py-4" aria-label="Mobile">
      {mainNav.map((item) => (
        <>
          <a href={lp(item.path)} class="block rounded-lg px-3 py-2 font-medium text-ink hover:bg-ocean-100">
            {t(item.key)}
          </a>
          {item.children?.filter((c) => c.path !== item.path).map((c) => (
            <a href={lp(c.path)} class="block rounded-lg py-2 pl-7 pr-3 text-sm text-ink-soft hover:bg-ocean-100">
              {t(c.key)}
            </a>
          ))}
        </>
      ))}
      <a href={lp('/contact/')} class="mt-2 block rounded-lg bg-ocean-700 px-3 py-2 text-center font-semibold text-sand-50">
        {t('cta.contact')}
      </a>
      <a href={WHATSAPP_URL} class="block rounded-lg border border-ocean-300 px-3 py-2 text-center font-semibold text-ocean-700">
        {t('cta.whatsapp')}
      </a>
    </nav>
  </div>
</header>

<script>
  // Re-bind on every View Transitions navigation (incl. the / → /<locale>/
  // redirect), not just first load — otherwise the hamburger is dead after nav.
  function bindMenu() {
    const toggle = document.getElementById('menu-toggle');
    const menu = document.getElementById('mobile-menu');
    if (!toggle || toggle.dataset.bound) return;
    toggle.dataset.bound = '1';
    toggle.addEventListener('click', () => {
      const open = menu?.classList.toggle('hidden') === false;
      toggle.setAttribute('aria-expanded', String(open));
    });
  }
  document.addEventListener('astro:page-load', bindMenu);
</script>
