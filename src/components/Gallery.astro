---
/**
 * Image gallery with a real lightbox (PhotoSwipe): on-screen arrows, keyboard
 * (←/→/Esc), pinch-zoom, swipe on mobile. Each thumbnail links to a large
 * (~1600px) variant with its dimensions so PhotoSwipe sizes correctly.
 */
import { Image, getImage } from 'astro:assets';
interface Props { images: ImageMetadata[]; alt: string; }
const { images, alt } = Astro.props;

// generate a large variant per image for the lightbox + carry its dimensions
const large = await Promise.all(
  images.map(async (img) => {
    const w = Math.min(1800, img.width);
    const h = Math.round((img.height * w) / img.width);
    const out = await getImage({ src: img, width: w, format: 'webp' });
    return { src: out.src, w, h };
  }),
);
---

<div class="pswp-gallery mt-5 columns-2 gap-3 sm:columns-3 [&>*]:mb-3">
  {images.map((img, i) => (
    <a
      href={large[i].src}
      data-pswp-width={large[i].w}
      data-pswp-height={large[i].h}
      target="_blank"
      rel="noopener"
      class="block break-inside-avoid overflow-hidden rounded-xl"
    >
      <Image src={img} alt={`${alt} ${i + 1}`} width={500} height={500} loading="lazy" class="w-full cursor-zoom-in transition duration-500 hover:scale-105" />
    </a>
  ))}
</div>

<script>
  import PhotoSwipeLightbox from 'photoswipe/lightbox';
  import 'photoswipe/style.css';

  let lb: any;
  function initPhotoSwipe() {
    if (lb) lb.destroy();
    if (!document.querySelector('.pswp-gallery')) return;
    lb = new PhotoSwipeLightbox({
      gallery: '.pswp-gallery',
      children: 'a',
      pswpModule: () => import('photoswipe'),
      bgOpacity: 0.92,
    });
    lb.init();
  }
  // fires on first load and after every View Transitions navigation
  document.addEventListener('astro:page-load', initPhotoSwipe);
</script>
