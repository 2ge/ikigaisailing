---
/** Standard page shell: BaseLayout + Header + Footer + WhatsApp + concierge. */
import BaseLayout from './BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import WhatsAppFloat from '../components/WhatsAppFloat.astro';
import Concierge from '../components/Concierge.astro';

interface Props {
  title: string;
  description: string;
  path?: string;
  ogImage?: string;
  ogType?: 'website' | 'article';
  alternates?: boolean;
  noindex?: boolean;
  /** concierge suggestion-chip context */
  conciergeContext?: 'home' | 'trip' | 'activity' | 'season' | 'generic';
}
const { conciergeContext = 'generic' } = Astro.props;
---

<BaseLayout {...Astro.props}>
  <slot name="head" slot="head" />
  <Header />
  <main id="main">
    <slot />
  </main>
  <Footer />
  <WhatsAppFloat />
  <Concierge context={conciergeContext} />
</BaseLayout>
