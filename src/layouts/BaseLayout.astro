---
/**
 * Base HTML shell for every page. Header/Footer come in Phase 2;
 * this layout owns <head> (via <SEO>), global styles, and analytics.
 */
import '@fontsource-variable/figtree';
import '@fontsource-variable/fraunces';
import { ClientRouter } from 'astro:transitions';
import SEO from '../components/SEO.astro';
import LocaleRedirect from '../components/LocaleRedirect.astro';
import Analytics from '../components/Analytics.astro';
import DebugBeacon from '../components/DebugBeacon.astro';
import { getLocaleFromUrl } from '../i18n/ui';
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  path?: string;
  ogImage?: string;
  ogType?: 'website' | 'article';
  alternates?: boolean;
  noindex?: boolean;
}

const locale = getLocaleFromUrl(Astro.url);
---

<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <LocaleRedirect />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" sizes="32x32" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <meta name="theme-color" content="#0e2b33" />
    <meta name="generator" content={Astro.generator} />
    <meta
      name="google-site-verification"
      content="CXcLaw_mODopdWa5K_eC21X4VXiL5s38jiNI0kStcnA"
    />
    <SEO {...Astro.props}>
      <slot name="head" />
    </SEO>
    <ClientRouter />
    {/* Instant navigations: prerender same-origin links on hover/viewport, zero framework JS */}
    <script
      type="speculationrules"
      is:inline
      set:html={JSON.stringify({
        prerender: [
          {
            source: 'document',
            where: { and: [{ href_matches: '/*' }, { not: { href_matches: '/api/*' } }] },
            eagerness: 'moderate',
          },
        ],
      })}
    />
    <Analytics />
  </head>
  <body class="min-h-screen bg-sand-50 font-sans text-ink antialiased">
    <slot />
    <DebugBeacon />
  </body>
</html>
