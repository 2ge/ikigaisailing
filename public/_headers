# Cloudflare Pages headers.
# Hashed build assets + fonts are immutable — cache hard.
/_astro/*
  Cache-Control: public, max-age=31536000, immutable
/fonts/*
  Cache-Control: public, max-age=31536000, immutable
/~partytown/*
  Cache-Control: public, max-age=31536000, immutable

# Images served from /_astro are already covered above; static originals:
/*.webp
  Cache-Control: public, max-age=2592000
/*.avif
  Cache-Control: public, max-age=2592000
/*.jpg
  Cache-Control: public, max-age=2592000

# HTML: let CF revalidate quickly (content can change on deploy)
/*
  X-Content-Type-Options: nosniff
