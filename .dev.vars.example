# Copy to .dev.vars for local `wrangler pages dev` — never commit either file.
# Runtime (Pages Functions):
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
RESEND_API_KEY=re_...
LISTMONK_URL=https://...
LISTMONK_API_KEY=...
TURNSTILE_SECRET=...
# Turnstile PUBLIC site key — build-time, must be prefixed PUBLIC_ to reach the
# client. Empty/unset = no captcha widget rendered on the contact form (and the
# server skips verification). Set BOTH this and TURNSTILE_SECRET to enable it.
PUBLIC_TURNSTILE_SITEKEY=
# Build-time only (lives in .env, not here — listed for completeness):
# DEEPL_API_KEY=...
# CLOUDFLARE_API_TOKEN=... (deploys)

# Google Places API (live reviews on /reviews/) — set these in Cloudflare Pages too
GOOGLE_MAPS_API_KEY=
GOOGLE_PLACE_ID=
